. * -- byte-only comparison: cmp.  Used for csv/xlsx/other ----------------------
. capture program drop cap_compare_bytes

. program define cap_compare_bytes, rclass
  1.     args pred_path cons_path ftype_tag
  2. 
.     capture shell cmp -s "`pred_path'" "`cons_path'"
  3.     local rc_cmp = _rc
  4. 
.     if `rc_cmp' == 0 {
  5.         return local status = "PASS"
  6.         return local details = "byte-identical"
  7.         exit
  8.     }
  9. 
.     if "`ftype_tag'" == "csv" {
 10.         return local status = "FAIL"
 11.         return local details = "csv byte-different (manual review)"
 12.         exit
 13.     }
 14.     return local status = "FAIL_BINARY"
 15.     return local details = "`ftype_tag' byte-different"
 16. end

