. /*==============================================================================
> PER-ROW DISPATCH LOOP
> 
>     Note on data-context discipline: the loop reads row metadata from the CSV
>     dataset, then dispatches to subroutines that themselves call `use` /
>     `estimates use`.  Those calls CLEAR the in-memory CSV dataset.  We must
>     therefore read all row fields into locals BEFORE the dispatch, and
>     re-load the CSV after each dispatch.  Idiom below uses `preserve`/`restore`
>     once around the entire forvalues loop body would not work (preserve is
>     bounded by the data; subroutine `use` would invalidate the snapshot
>     pointer).  Instead, we cache the entire CSV into a tempfile, then re-use
>     it inside each iteration via `frame put` is overkill — simpler: read the
>     CSV once into Mata-like vectors, OR re-import the CSV after each dispatch.
>     We use the latter via a tempfile snapshot for clarity.
> ==============================================================================*/
. 
. * Snapshot the (filtered) matrix to a tempfile so we can re-read after each
. * dispatch (which `use`s the predecessor .dta and clobbers our CSV in-memory).
. tempfile matrix_snapshot

. save "`matrix_snapshot'", replace
(file /home/tmp/St48258.000001 not found)
file /home/tmp/St48258.000001 saved as .dta format

. 
. * Counters for tally block
. local n_pass         = 0

. local n_fail         = 0

. local n_missing_pred = 0

. local n_missing_cons = 0

. local n_read_err     = 0

. local n_fail_visual  = 0

. local n_fail_binary  = 0

. local n_skip         = 0

. local n_unknown      = 0

. 
. * Wall-clock start (for runtime reporting)
. local start_time = clock("`c(current_date)' `c(current_time)'", "DMYhms")

. 
. * Stash relative-path prefix for compact output
. local cons_root = "$consolidated_dir"

. local cons_root_len = length("`cons_root'") + 1   // +1 to skip trailing slash

. 
. forvalues i = 1/`n_rows' {
  2. 
.     * Re-load row metadata from snapshot (subroutines clobber the data).
.     quietly use "`matrix_snapshot'", clear
  3. 
.     local pred_path  = predecessor_abs_path[`i']
  4.     local cons_path  = consolidated_abs_path[`i']
  5.     local prod_file  = producer_file[`i']
  6.     local ftype      = filetype[`i']
  7.     local row_tier   = tier[`i']
  8.     local cat        = category[`i']
  9. 
.     * Compact relpath = consolidated_abs_path with $consolidated_dir/ stripped
.     local cons_relpath = substr("`cons_path'", `cons_root_len' + 1, .)
 10.     if "`cons_relpath'" == "" {
 11.         local cons_relpath = "`cons_path'"   // fallback if prefix didn't match
 12.     }
 13. 
.     * Progress every 100 rows
.     if mod(`i', 100) == 0 | `i' == 1 | `i' == `n_rows' {
 14.         local now = clock("`c(current_date)' `c(current_time)'", "DMYhms")
 15.         local elapsed_min = (`now' - `start_time') / 60000
 16.         di as text "  row `i' / `n_rows'  (`:di %5.1f `elapsed_min'' min elapsed)"
 17.     }
 18. 
.     * Pre-flight: do BOTH files exist?
.     capture confirm file "`pred_path'"
 19.     local pred_exists = (_rc == 0)
 20. 
.     capture confirm file "`cons_path'"
 21.     local cons_exists = (_rc == 0)
 22. 
.     local status = ""
 23.     local details = ""
 24. 
.     if !`pred_exists' & !`cons_exists' {
 25.         local status  = "MISSING_PREDECESSOR"
 26.         local details = "neither side exists; cons=`cons_path'"
 27.         local ++n_missing_pred
 28.     }
 29.     else if !`pred_exists' {
 30.         local status  = "MISSING_PREDECESSOR"
 31.         local details = "pred not found: `pred_path'"
 32.         local ++n_missing_pred
 33.     }
 34.     else if !`cons_exists' {
 35.         local status  = "MISSING_CONSOLIDATED"
 36.         local details = "cons not found: `cons_path'"
 37.         local ++n_missing_cons
 38.     }
 39.     else {
 40. 
.         * Both exist — dispatch by filetype
.         if "`ftype'" == "dta" {
 41.             cap_compare_dta `"`pred_path'"' `"`cons_path'"' `has_cfout'
 42.             local status  = "`r(status)'"
 43.             local details = "`r(details)'"
 44.         }
 45.         else if "`ftype'" == "ster" {
 46.             cap_compare_ster `"`pred_path'"' `"`cons_path'"'
 47.             local status  = "`r(status)'"
 48.             local details = "`r(details)'"
 49.         }
 50.         else if "`ftype'" == "tex" {
 51.             cap_compare_tex `"`pred_path'"' `"`cons_path'"'
 52.             local status  = "`r(status)'"
 53.             local details = "`r(details)'"
 54.         }
 55.         else if "`ftype'" == "pdf" {
 56.             cap_compare_pdf `"`pred_path'"' `"`cons_path'"' `has_pdftotext'
 57.             local status  = "`r(status)'"
 58.             local details = "`r(details)'"
 59.         }
 60.         else if "`ftype'" == "csv" {
 61.             cap_compare_bytes `"`pred_path'"' `"`cons_path'"' "csv"
 62.             local status  = "`r(status)'"
 63.             local details = "`r(details)'"
 64.         }
 65.         else if "`ftype'" == "xlsx" {
 66.             cap_compare_bytes `"`pred_path'"' `"`cons_path'"' "xlsx"
 67.             local status  = "`r(status)'"
 68.             local details = "`r(details)'"
 69.         }
 70.         else if "`ftype'" == "other" {
 71.             cap_compare_bytes `"`pred_path'"' `"`cons_path'"' "other"
 72.             local status  = "`r(status)'"
 73.             local details = "`r(details)'"
 74.         }
 75.         else {
 76.             local status  = "UNKNOWN_FILETYPE"
 77.             local details = "filetype=`ftype' has no dispatcher"
 78.         }
 79. 
.         * Update counters by status
.         if "`status'" == "PASS"               local ++n_pass
 80.         else if "`status'" == "FAIL"          local ++n_fail
 81.         else if "`status'" == "READ_ERROR"    local ++n_read_err
 82.         else if "`status'" == "FAIL_VISUAL"   local ++n_fail_visual
 83.         else if "`status'" == "FAIL_BINARY"   local ++n_fail_binary
 84.         else if "`status'" == "SKIP"          local ++n_skip
 85.         else                                  local ++n_unknown
 86.     }
 87. 
.     * Pad columns for grep-ability.
.     local status_pad = "`status'" + substr("                       ", 1, max(0, 22 - length("`status'")))
 88.     local tier_pad   = "`row_tier'" + substr("       ", 1, max(0, 6 - length("`row_tier'")))
 89.     local ftype_pad  = "`ftype'" + substr("       ", 1, max(0, 6 - length("`ftype'")))
 90. 
.     file write `fh' "`status_pad'  `tier_pad'  `ftype_pad'  `cons_relpath'  `details'" _n
 91. }
