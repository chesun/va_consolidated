. * -- ster comparison: load both, compare e(b) + sqrt(diag(e(V))) --------------
. capture program drop cap_compare_ster

. program define cap_compare_ster, rclass
  1.     args pred_path cons_path
  2. 
.     * Load predecessor estimates
.     capture estimates use "`pred_path'"
  3.     if _rc {
  4.         return local status = "READ_ERROR"
  5.         return local details = "rc=`_rc' loading pred .ster"
  6.         exit
  7.     }
  8.     tempname b1 V1
  9.     capture matrix `b1' = e(b)
 10.     local has_b1 = (_rc == 0)
 11.     capture matrix `V1' = e(V)
 12.     local has_V1 = (_rc == 0)
 13. 
.     if !`has_b1' {
 14.         return local status = "SKIP"
 15.         return local details = "pred .ster has no e(b) — non-estimation save"
 16.         exit
 17.     }
 18. 
.     local nc1 = colsof(`b1')
 19. 
.     * Load consolidated estimates
.     capture estimates use "`cons_path'"
 20.     if _rc {
 21.         return local status = "READ_ERROR"
 22.         return local details = "rc=`_rc' loading cons .ster"
 23.         exit
 24.     }
 25.     tempname b2 V2
 26.     capture matrix `b2' = e(b)
 27.     local has_b2 = (_rc == 0)
 28.     capture matrix `V2' = e(V)
 29.     local has_V2 = (_rc == 0)
 30. 
.     if !`has_b2' {
 31.         return local status = "FAIL"
 32.         return local details = "cons .ster has no e(b) (pred had `nc1' coefs)"
 33.         exit
 34.     }
 35. 
.     local nc2 = colsof(`b2')
 36.     if `nc1' != `nc2' {
 37.         return local status = "FAIL"
 38.         return local details = "coef vector size mismatch: pred=`nc1' cons=`nc2'"
 39.         exit
 40.     }
 41. 
.     * Compare element-wise.  b is 1 x K row vector.
.     local max_b_diff  = 0
 42.     local max_se_diff = 0
 43.     forvalues k = 1/`nc1' {
 44.         local b1k = `b1'[1,`k']
 45.         local b2k = `b2'[1,`k']
 46.         if !missing(`b1k') & !missing(`b2k') {
 47.             local d = abs(`b1k' - `b2k')
 48.             if `d' > `max_b_diff' local max_b_diff = `d'
 49.         }
 50.         if `has_V1' & `has_V2' {
 51.             capture {
 52.                 local v1k = `V1'[`k',`k']
 53.                 local v2k = `V2'[`k',`k']
 54.                 if !missing(`v1k') & !missing(`v2k') & `v1k' >= 0 & `v2k' >= 0 {
 55.                     local se1 = sqrt(`v1k')
 56.                     local se2 = sqrt(`v2k')
 57.                     local sed = abs(`se1' - `se2')
 58.                     if `sed' > `max_se_diff' local max_se_diff = `sed'
 59.                 }
 60.             }
 61.         }
 62.     }
 63. 
.     * Tolerance per replication-protocol.md §3.  Diff magnitudes (max|db|,
.     * max|dSE|) are summary-class quantities and are reported in the `details`
.     * string so offline triage can compare against the 0.01 / 0.05 tolerances
.     * without re-running on Scribe.  Also printed to the log for redundancy.
.     display as text "  [ster diag] max|db|=" %7.4f `max_b_diff' "  max|dSE|=" %7.4f `max_se_diff'
 64.     if (`max_b_diff' <= 0.01) & (`max_se_diff' <= 0.05) {
 65.         return local status = "PASS"
 66.         return local details = "coef and SE within tolerance (max|db|=`:di %7.4f `max_b_diff'' max|dSE|=`:di %7.4f `max_se_diff'')"
 67.         exit
 68.     }
 69. 
.     return local status = "FAIL"
 70.     return local details = "max|db|=`:di %7.4f `max_b_diff'' max|dSE|=`:di %7.4f `max_se_diff''"
 71. end

