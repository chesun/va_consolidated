. * -- tex comparison: byte-cmp; fallback to numeric-strip awk + diff -----------
. capture program drop cap_compare_tex

. program define cap_compare_tex, rclass
  1.     args pred_path cons_path
  2. 
.     capture shell cmp -s "`pred_path'" "`cons_path'"
  3.     local rc_cmp = _rc
  4. 
.     if `rc_cmp' == 0 {
  5.         return local status = "PASS"
  6.         return local details = "byte-identical"
  7.         exit
  8.     }
  9. 
.     * Files differ.  Strip numeric tokens (digits, dot, minus, exponent) and
.     * re-diff to check whether the only differences are within numeric
.     * rounding (a heuristic).  Use bash process substitution.
.     tempfile stripped_diff
 10.     capture shell bash -c "diff <(awk '{gsub(/-?[0-9]+(\\.[0-9]+)?([eE][-+]?[0-9]+)?/, \"NUM\"); print}' '`pred_path'') <(awk '{gsub(/-?[0-9]+(\\.[0-9]+)?([eE][-+]?[0-9]+)?/, \"NUM\"); print}' '`
> cons_path'') > '`stripped_diff'' 2>/dev/null; wc -l < '`stripped_diff'' > '`stripped_diff'.count'"
 11.     local rc_strip = _rc
 12. 
.     if `rc_strip' == 0 {
 13.         tempname fh_sd
 14.         capture file open `fh_sd' using "`stripped_diff'.count", read
 15.         if !_rc {
 16.             file read `fh_sd' line
 17.             file close `fh_sd'
 18.             local n_struct_diff = trim("`line'")
 19.             if "`n_struct_diff'" == "0" {
 20.                 return local status = "PASS"
 21.                 return local details = "numeric-only diff (structure identical)"
 22.                 exit
 23.             }
 24.             return local status = "FAIL"
 25.             return local details = "diff: `n_struct_diff' structural-diff lines"
 26.             exit
 27.         }
 28.     }
 29. 
.     return local status = "FAIL"
 30.     return local details = "byte-different (numeric-strip diff rc=`rc_strip')"
 31. end

. 
. 
. * -- pdf comparison: byte-cmp; fallback to pdftotext + diff -------------------
. capture program drop cap_compare_pdf

. program define cap_compare_pdf, rclass
  1.     args pred_path cons_path has_pdftotext
  2. 
.     capture shell cmp -s "`pred_path'" "`cons_path'"
  3.     local rc_cmp = _rc
  4. 
.     if `rc_cmp' == 0 {
  5.         return local status = "PASS"
  6.         return local details = "byte-identical"
  7.         exit
  8.     }
  9. 
.     if !`has_pdftotext' {
 10.         return local status = "FAIL_BINARY"
 11.         return local details = "pdfs differ byte-wise (no pdftotext available)"
 12.         exit
 13.     }
 14. 
.     * Run pdftotext on each and compare the text streams.
.     tempfile ptxt1 ptxt2
 15.     capture shell pdftotext -layout "`pred_path'" "`ptxt1'" 2>/dev/null
 16.     local rc1 = _rc
 17.     capture shell pdftotext -layout "`cons_path'" "`ptxt2'" 2>/dev/null
 18.     local rc2 = _rc
 19. 
.     if `rc1' | `rc2' {
 20.         return local status = "FAIL_VISUAL"
 21.         return local details = "pdftotext rc1=`rc1' rc2=`rc2'"
 22.         exit
 23.     }
 24. 
.     capture shell cmp -s "`ptxt1'" "`ptxt2'"
 25.     local rc_text = _rc
 26. 
.     if `rc_text' == 0 {
 27.         return local status = "PASS"
 28.         return local details = "byte-different, text-identical via pdftotext"
 29.         exit
 30.     }
 31. 
.     return local status = "FAIL_VISUAL"
 32.     return local details = "pdf text-streams differ (need offline visual review)"
 33. end

. 
