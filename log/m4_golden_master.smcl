. /*==============================================================================
> SUBROUTINE DEFINITIONS (must come before the dispatch loop)
> 
>     Each returns r(status) + r(details) via `return local`.  All commands
>     inside use `capture` so a bad file's error surfaces as a READ_ERROR
>     status rather than killing the do-file.
> 
>     `cap program drop` at top of each so re-running the .do file in the same
>     Stata session (rare for one-shot M4, but defensive) doesn't error on
>     "program already defined".
> ==============================================================================*/
. 
. 
. * -- dta comparison via `cf` --------------------------------------------------
. capture program drop cap_compare_dta

. program define cap_compare_dta, rclass
  1.     args pred_path cons_path has_cfout
  2. 
.     capture {
  3.         quietly use "`pred_path'", clear
  4.         quietly cf _all using "`cons_path'"
  5.     }
  6.     if _rc {
  7.         return local status = "READ_ERROR"
  8.         return local details = "rc=`_rc' on cf _all"
  9.         exit
 10.     }
 11. 
.     * cf populates r(Nsum) = total number of differing observations across vars.
.     * If 0 -> no row-level mismatch.
.     local nsum = r(Nsum)
 12.     if missing(`nsum') local nsum = 0
 13. 
.     if `nsum' == 0 {
 14.         return local status = "PASS"
 15.         return local details = "cf _all: 0 cumulative diffs"
 16.         exit
 17.     }
 18. 
.     * Diffs found.  If cfout available, get cell-level diff count for context.
.     if `has_cfout' {
 19.         tempfile cfout_tmp
 20.         capture {
 21.             quietly use "`pred_path'", clear
 22.             quietly cfout _all using "`cons_path'", saving("`cfout_tmp'") replace
 23.         }
 24.         if _rc {
 25.             return local status = "FAIL"
 26.             return local details = "cf:`nsum' obs-diffs (cfout fallback rc=`_rc')"
 27.             exit
 28.         }
 29.         local nd = r(diffs)
 30.         if missing(`nd') local nd = `nsum'
 31.         return local status = "FAIL"
 32.         return local details = "cf:`nsum' obs-diffs; cfout:`nd' cell-diffs"
 33.         exit
 34.     }
 35. 
.     return local status = "FAIL"
 36.     return local details = "cf _all: `nsum' cumulative diffs"
 37. end

. 
