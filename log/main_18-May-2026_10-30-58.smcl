. *****************
. 
. //debug
. /* set trace on */
. 
. 
. forvalues fall_year = `= `test_score_min_year' - 1' (1) `= `test_score_max_year' - 1' {
  2.         di "Fall Year = `fall_year'"
  3. 
.         local spring_year = `fall_year' + 1
  4.         local fall_year_stub = substr(string(`fall_year'), 3, 2)
  5.         local spring_year_stub = substr(string(`spring_year'), 3, 2)
  6. 
.         //the end of the cell range is optional. Stata will detect automatically if not specified. Different years of 
> these datasets have different end rows.
.         // 1718 and 1819 data are .xlsx formats
.         if ( `fall_year'==2017 | `fall_year'==2018 ) {
  7.                 import excel $vaprojdir/data/public_access/raw/cde/frpm/frpm`fall_year_stub'`spring_year_stub'.xlsx
> , sheet("FRPM School-Level Data ") cellrange(A2) firstrow case(lower) allstring clear
  8.         }
  9.         else {
 10.                 import excel $vaprojdir/data/public_access/raw/cde/frpm/frpm`fall_year_stub'`spring_year_stub'.xls,
>  sheet("FRPM School-Level Data ") cellrange(A2) firstrow case(lower) allstring clear
 11.         }
 12. 
.         gen cdscode = countycode + districtcode + schoolcode
 13. 
.         destring enrollmentk12, gen(enrollment_k12)
 14.         drop enrollmentk12
 15.         destring freemealcountk12, gen(freemeals_k12)
 16.         drop freemealcountk12
 17.         destring percenteligiblefreek1, gen(freemeals_k12_prop)
 18.         drop percenteligiblefreek1
 19.         destring frpmcountk12, gen(totalfrpm_k12)
 20.         drop frpmcountk12
 21.         destring percenteligiblefrpmk1, gen(frpm_k12_prop)
 22.         drop percenteligiblefrpmk1
 23. 
.         destring enrollmentages517, gen(enrollment)
 24.         drop enrollmentages517
 25.         destring freemealcountages517, gen(freemeals)
 26.         drop freemealcountages517
 27.         destring percenteligiblefreeage, gen(freemeals_prop)
 28.         drop percenteligiblefreeage
 29.         destring frpmcountages517, gen(totalfrpm)
 30.         drop frpmcountages517
 31.         destring percenteligiblefrpmage, gen(frpm_prop)
 32.         drop percenteligiblefrpmage
 33. 
.         rename ab calpads_certification
 34. 
.         gen year = `fall_year' + 1
 35.         label var year "Year of Spring Semester"
 36. 
.         order cdscode year
 37.         sort cdscode year
 38.         compress
 39.         label data "California Department of Education Spring `=`fall_year' + 1' Free and Reduced Price Meals"
 40.         save $datadir_clean/cde/frpm/frpm_`=`fall_year' + 1'_clean.dta, replace
 41. }
