>  varnames(1) case(lower) stringcols(1 2 3) encoding("utf-8") clear
  5.         desc, full
  6.         codebook
  7. 
.         label var academicyear "Academic Year"
  8. 
.         label var recid "Record ID"
  9. 
.         label var districtcode "District Code"
 10. 
.         label var countyname "County name"
 11. 
.         label var districtname "District name"
 12. 
.         label var gendercode "Gender"
 13. 
.         label def male 1 "Male" 0 "Female"
 14.         gen male:male = 1 if gendercode=="M"
 15.         replace male = 0 if gendercode=="F"
 16.         replace male = . if mi(gendercode)
 17.         label var male "Male"
 18.         drop gendercode
 19. 
.         label var educationlevel "Staff member's highest educational level (honorary degrees not included)"
 20. 
.         label def education 1 "Doctorate"
 21.         label def education 2 "Master's degree plus 30 or more semester hours", add
 22.         label def education 3 "Master's degree", add
