>         peer_loscore
>         `peer_census_controls'
>         `peer_sibling_controls'
>         ;

. foreach control in b l a s la ls as las {;
  2.         local `control'd_controls
>                 ``control'_controls' `d_controls'
>                 ;
  3.         local peer_`control'd_controls
>                 `peer_`control'_controls'
