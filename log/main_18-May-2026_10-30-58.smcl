. /*------------------------------------------------------------------------------
> do/data_prep/qoiclean/parent/parentqoiclean1819_1718.do — Phase 1a §3.3 step 9 batch 9e relocation
> ================================================================================
> 
> PURPOSE
>     QOI (Question Of Interest) cleaning for parent CalSCHLS, year 1819_1718.
>     Cleans Likert survey items + computes school-level pooled means.
>     Year-by-year worker file (1 of 10 sister files in this batch).
> 
> INVOKED FROM
>     `do/main.do' Phase 1 (DATA PREP) under flag `do_data_prep'.  Chain
>     consumer: reads renamed CalSCHLS yearly data produced by
>     renamedata.do (batch 9d) earlier in main.do invocation order.
> 
> INPUTS (verified via grep on file body)
>     $datadir_clean/calschls/parent/parent`year'  (CHAIN read across {1718,1819}; from renamedata batch 9d)
> 
> OUTPUTS (CANONICAL per ADR-0021 sandbox; verified via grep on file body)
>     $datadir_clean/calschls/qoiclean/parent/parentqoiclean`year'
>     $logdir/data_prep/qoiclean/parent/parentqoiclean1819_1718.smcl (via log using)
>     $logdir/data_prep/qoiclean/parent/parentqoiclean1819_1718.smcl + $logdir/data_prep/qoiclean/parent/parentqoiclean1
> 819_1718.log (translate)
> 
> RELOCATION (per plan v3 §3.3 step 9 batch 9e, applied 2026-05-08)
>     Source: caschls/do/build/buildanalysisdata/qoiclean/parent/parentqoiclean1819_1718.do
>     Path repointing applied (script-based methodology):
>       $projdir/log/build/buildanalysisdata/qoiclean/<sub>/<x>.smcl
>         -> $logdir/<x>.smcl  (CANONICAL — flattened from nested predecessor structure)
>       $projdir/dta/buildanalysisdata/qoiclean/<sub>/<x>
>         -> $datadir_clean/calschls/qoiclean/<sub>/<x>  (CANONICAL chain output)
>       $clndtadir/<sub>/<x> (read) -> $datadir_clean/calschls/<sub>/<x>
>         (CHAIN read; produced by renamedata batch 9d in same Stata session)
>       translate (single-line ABS form) -> $logdir/<x> (CANONICAL)
> 
> REFERENCES
>     ADRs:   0021 (sandbox; description convention)
>     Plan:   v3 §3.3 step 9 batch 9e (final batch of Step 9)
>     Sister files (this batch): 9 other qoiclean files (parent×4, secondary×3, staff×3)
> 
> ORIGINAL HEADER preserved verbatim below.
> ------------------------------------------------------------------------------*/
. 
. 
. ********************************************************************************
. /* rename and clean parent 1819 and 1718 survey questions of interest. This file
> supercedes parentqoiclean1718.do*/
. ********************************************************************************
. ********************************************************************************
. *************** written by Che Sun. Email: ucsun@ucdavis.edu *******************
. ********************************************************************************
. cap log close parentqoiclean1819_1718

. clear all

. set more off

. 
. * --- output-directory prep (CANONICAL) ---------------------------------------
. cap mkdir "$logdir"

. cap mkdir "$logdir/data_prep"

. cap mkdir "$logdir/data_prep/qoiclean"

. cap mkdir "$logdir/data_prep/qoiclean/parent"

. cap mkdir "$datadir_clean"

. cap mkdir "$datadir_clean/calschls"

. cap mkdir "$datadir_clean/calschls/qoiclean"

. cap mkdir "$datadir_clean/calschls/qoiclean/parent"

. 
. log using "$logdir/data_prep/qoiclean/parent/parentqoiclean1819_1718.smcl", replace text name(parentqoiclean1819_1718)
------------------------------------------------------------------------------------------------------------------------
      name:  parentqoiclean1819_1718
       log:  /home/research/ca_ed_lab/projects/common_core_va/consolidated/log/data_prep/qoiclean/parent/parentqoiclean1
> 819_1718.smcl
  log type:  text
 opened on:  18 May 2026, 12:12:26

. 
. /* the code for cleaning 1819 and 1718 is exactly the same, so use loop */
. local years `" "1718" "1819" "'

. 
. foreach year of local years {
  2. use $datadir_clean/calschls/parent/parent`year', clear
  3. //only keep questions of interest
. keep cdscode p9 p15 p16 p17 p27 p30 p31 p32 p33 p34 p64
  4. //rename questions of interest using question numbers in 1819 as standard
. foreach i of numlist 9 15/17 27 30/34 64 {
  5.   rename p`i' qoi`i'
  6. }
  7. //relabel the value labels to be consistent with var name
. elabel rename (p*) (qoi*)
  8. //delete all value labels not associated with variables
. labdu , delete
  9. 
. /* count the total number of responses in each school */
. sort cdscode
 10. by cdscode: gen totalresp = _N
 11. label var totalresp "total number of responses at each school including missing"
 12. 
. 
. ********************************************************************************
. /* qoi 9, 15-17, 27, 30-34 have the same response options, so clean them in the
> same batch */
. 
. /* value labels for qoi 9, 15-17, 27, 30-34:
> 1 strongly agree
> 2 agree
> 3 disagree
> 4 strongly disagree
> 5 don't know/NA
> 
> Recode:
> -2 strongly disagree
> -1 disagree
> 0 neutral
> 1 agree
> 2 strongly agree
> */
. 
. /* recode qoi 9, 15-17, 27, 30-34 */
. foreach i of numlist 9 15/17 27 30/34 {
 13.   gen qoi`i'temp = .
 14.   replace qoi`i'temp = -2 if qoi`i' == 4
 15.   replace qoi`i'temp = -1 if qoi`i' == 3
 16.   replace qoi`i'temp =  0 if qoi`i' == 5
 17.   replace qoi`i'temp =  1 if qoi`i' == 2
 18.   replace qoi`i'temp =  2 if qoi`i' == 1
 19. 
.   drop qoi`i'
 20.   rename qoi`i'temp qoi`i'
 21. }
 22. 
. /* generate dummies for each response option and missing for qoi 9, 15-17, 27, 30-34 */
. foreach i of numlist 9 15/17 27 30/34 {
 23.   gen stragree`i' = 0
 24.   replace stragree`i' = 1 if qoi`i' == 2
 25. 
.   gen agree`i' = 0
 26.   replace agree`i' = 1 if qoi`i' == 1
 27. 
.   gen disagree`i' = 0
 28.   replace disagree`i' = 1 if qoi`i' == -1
 29. 
.   gen strdisagree`i' = 0
 30.   replace strdisagree`i' = 1 if qoi`i' == -2
 31. 
.   gen dontknow`i' = 0
 32.   replace dontknow`i' = 1 if qoi`i' == 0
 33. 
.   gen missing`i' = 0
 34.   replace missing`i' = 1 if missing(qoi`i')
 35. }
 36. 
. ********************************************************************************
. /* clean qoi 64 as it has different resonse options */
. 
. /* value labels for qoi64:
> 1 very well
> 2 just okay
> 3 not very well
> 4 does not do it at all
> 5 don't know/NA
> 
> recode:
> -2 does not do it at all
> -1 not very well
> 0 dont know
> 1 just okay
> 2 very well
>  */
. 
. /* recode qoi 64 */
.  gen qoi64temp = .
 37.  replace qoi64temp = -2 if qoi64 == 4
 38.  replace qoi64temp = -1 if qoi64 == 3
 39.  replace qoi64temp =  0 if qoi64 == 5
 40.  replace qoi64temp =  1 if qoi64 == 2
 41.  replace qoi64temp =  2 if qoi64 == 1
 42. 
.  drop qoi64
 43.  rename qoi64temp qoi64
 44. 
.  gen verywell64 = 0
 45.  replace verywell64 = 1 if qoi64 == 2
 46. 
.  gen justokay64 = 0
 47.  replace justokay64 = 1 if qoi64 == 1
 48. 
.  gen notwell64 = 0
 49.  replace notwell64 = 1 if qoi64 == -1
 50. 
.  gen doesnotdo64 = 0
 51.  replace doesnotdo64 = 1 if qoi64 == -2
 52. 
.  gen dontknow64 = 0
 53.  replace dontknow64 = 1 if qoi64 == 0
 54. 
.  gen missing64 = 0
 55.  replace missing64 = 1 if missing(qoi64)
 56. 
. 
. /* generate means for the qoi  */
. foreach i of numlist 9 15/17 27 30/34 64 {
 57.   egen qoi`i'mean = mean(qoi`i'), by(cdscode)
 58. }
 59. 
. 
. /* This is old code before the recoding of qoi values
>  /<x> generate mean of vars, excluding don't know. <x>
>  //generate temp vars for low and high bounds to use with rangestat
>  gen lowbound = 1
>  gen highbound = 4
> foreach i of numlist 9 15/17 27 30/34 64 {
>   rangestat (mean) qoi`i', interval(qoi`i' lowbound highbound) by(cdscode)
>   rename qoi`i'_mean qoi`i'mean //rename the generated mean vars
> }
> /<x> Note: don't worry about missing values generated because it does not matter
> after collapsing dataset <x>
> drop lowbound highbound //drop the temp vars */
. 
. 
. 
. /* collapse the dataset, resulting dataset has mean for each qoi, total number
> of responses, and number of responses for each option in each question */
. collapse (mean) qoi*mean totalresp (sum) stragree* agree* disagree* strdisagree* dontknow* missing* verywell64 justoka
> y64 notwell64 doesnotdo64, by(cdscode)
 60. //some schools have missing means because they have very low number of responses and with either don't know or miss
> ing
. 
. 
. **************************** relabel the vars **********************************
. /* label mean vars */
. label var qoi9mean "Mean (excluding don't know) of Q: promotes academic success for all students"
 61. label var qoi15mean "Mean (excluding don't know) of Q: provides quality counseling or other ways..."
 62. label var qoi16mean "Mean (excluding don't know) of Q: is a supportive and inviting place..."
 63. label var qoi17mean "Mean (excluding don't know) of Q: allows input and welcomes parents'..."
 64. label var qoi27mean "Mean (excluding don't know) of Q: encourages me to be an active partner..."
 65. label var qoi30mean "Mean (excluding don't know) of Q: provides high quality instruction..."
 66. label var qoi31mean "Mean (excluding don't know) of Q: motivates students to learn"
 67. label var qoi32mean "Mean (excluding don't know) of Q: has teachers who go out of their way..."
 68. label var qoi33mean "Mean (excluding don't know) of Q: has adults who really care about students"
 69. label var qoi34mean "Mean (excluding don't know) of Q: has high expectations for all students"
 70. label var qoi64mean "Mean (excluding don't know) of Q: provoding information on how to help..."
 71. 
. label var totalresp "total number of responses in the school including missing"
 72. 
. /* label vars for the number of response for each option */
. foreach i of numlist 9 15/17 27 30/34 {
 73.   label var stragree`i' "number of people choosing strongly agree for qoi`i'"
 74.   label var agree`i' "number of people choosing agree for qoi`i'"
 75.   label var disagree`i' "number of people choosing disagree for qoi`i'"
 76.   label var strdisagree`i' "number of people choosing strongly disagree for qoi`i'"
 77.   label var dontknow`i' "number of people choosing don't know for qoi`i'"
 78.   label var missing`i' "number of missing responses for qoi`i'"
 79. }
 80. 
. label var verywell64 "number of people choosing very well for qoi64"
 81. label var justokay64 "number of people choosing just okay for qoi64"
 82. label var notwell64 "number of people choosing not very well for qoi64"
 83. label var doesnotdo64 "number of people choosing does not do it at all for qoi64"
 84. label var dontknow64 "number of people choosing don't know for qoi64"
 85. label var missing64 "number of missing responses for qoi64"
 86. 
. ********************* generate percentage agree/disagree etc *******************
. /* first, generate the net total responses for each question excluding missing */
. foreach i of numlist 9 15/17 27 30/34 64 {
 87.   gen nettotalresp`i' = totalresp - missing`i'
 88.   label var nettotalresp`i' "net total responses for qoi`i' excluding missing "
 89. }
 90. 
. /* generate percent disagree/agree for qoi 9 15/17 27 30/34 */
. foreach i of numlist 9 15/17 27 30/34 {
 91.   gen pctdisagree`i' = (strdisagree`i' + disagree`i')/nettotalresp`i'
 92.   label var pctdisagree`i' "percent strongly disagree or disagree in qoi`i'"
 93.   gen pctagree`i' = (stragree`i' + agree`i')/nettotalresp`i'
 94.   label var pctagree`i' "percent strongly agree or agree in qoi`i'"
 95.   gen pctdontknow`i' = dontknow`i'/nettotalresp`i'
 96.   label var pctdontknow`i' "percent don't know in qoi`i'"
 97. }
 98. 
. /* generate percent well/not well for qoi64 */
. gen pctwell64 = verywell64/nettotalresp64
 99. label var pctwell64 "percent very well in qoi64"
100. gen pctokay64 = justokay64/nettotalresp64
101. label var pctokay64 "percent just okay in qoi64"
102. gen pctnotwell64 = (notwell64 + doesnotdo64)/nettotalresp64
103. label var pctnotwell64 "percent not well or does not do at all in qoi64"
104. gen pctdontknow64 = dontknow64/nettotalresp64
105. label var pctdontknow64 "percent don't know in qoi64"
106. 
. /* generate a year var to prepare for constructing a panel */
. gen year = `year'
107. 
. 
. label data "cleaned parent `year' survey questions of interest with percent disagree/agree etc."
108. compress
109. save $datadir_clean/calschls/qoiclean/parent/parentqoiclean`year', replace
110. }
