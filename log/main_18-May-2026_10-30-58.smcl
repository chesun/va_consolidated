  5.   label var pctagree`i' "percent strongly agree or agree in qoi`i'"
  6.   gen pctdontknow`i' = dontknow`i'/nettotalresp`i'
  7.   label var pctdontknow`i' "percent don't know in qoi`i'"
  8. }
