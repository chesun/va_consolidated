. ********************************************************************************
. /* trim demographics data for secondary survey and rename vars to prepare for
> generating conditional response rate datasets */
. ********************************************************************************
. ********************************************************************************
. *************** written by Che Sun. Email: ucsun@ucdavis.edu ********************
. ********************************************************************************
. cap log close trimsecdemo

. clear

. set more off

. 
. * --- output-directory prep (CANONICAL) ---------------------------------------
. cap mkdir "$logdir"

. cap mkdir "$logdir/data_prep"

. cap mkdir "$logdir/data_prep/responserate"

. cap mkdir "$datadir_clean"

. cap mkdir "$datadir_clean/calschls"

. cap mkdir "$datadir_clean/calschls/demotrim"

. cap mkdir "$datadir_clean/calschls/demotrim/secondary"

. 
. log using "$logdir/data_prep/responserate/trimsecdemo.smcl", replace text name(trimsecdemo)
(file /home/research/ca_ed_lab/projects/common_core_va/consolidated/log/data_prep/responserate/trimsecdemo.smcl not
    found)
------------------------------------------------------------------------------------------------------------------------
      name:  trimsecdemo
       log:  /home/research/ca_ed_lab/projects/common_core_va/consolidated/log/data_prep/responserate/trimsecdemo.smcl
  log type:  text
 opened on:  18 May 2026, 12:13:15

. 
. ********************************************************************************
. /* rename variables in the secondary demographics datasets to indicate year, keep only vars needed to calculate respon
> se rates */
. local grades `" "9" "10" "11" "12" "' //local macro for grades

. 
. use $caschls_projdir/dta/demographics/secondary/secdemo1415, replace

. keep cdscode svygr9 svygr10 svygr11 svygr12 gr9enr gr10enr gr11enr gr12enr

. //renaming vars to indicate the year of the dataset to prepare for merging with other years later
. foreach i of local grades {
  2.   rename svygr`i' svygr`i'_1415
  3.   rename gr`i'enr enrgr`i'_1415
  4.   label var svygr`i'_1415 "number of grade `i' responses in 1415"
  5.   label var enrgr`i'_1415 "grade `i' enrollment in 1415"
  6. }

. label data "trimmed secondary demographics 1415 including only survey response and enrollment for grades 9-12"
note: label truncated to 80 characters

. compress
  (0 bytes saved)

. save $datadir_clean/calschls/demotrim/secondary/trimsecdemo1415, replace
