.     do do/data_prep/qoiclean/staff/staffqoiclean1617_1516.do         // QOI clean staff CalSCHLS 1516+1617 (loop)

. /*------------------------------------------------------------------------------
> do/data_prep/qoiclean/staff/staffqoiclean1617_1516.do — Phase 1a §3.3 step 9 batch 9e relocation
> ================================================================================
> 
> PURPOSE
>     QOI (Question Of Interest) cleaning for staff CalSCHLS, year 1617_1516.
>     Cleans Likert survey items + computes school-level pooled means.
>     Year-by-year worker file (1 of 10 sister files in this batch).
> 
> INVOKED FROM
>     `do/main.do' Phase 1 (DATA PREP) under flag `do_data_prep'.  Chain
>     consumer: reads renamed CalSCHLS yearly data produced by
>     renamedata.do (batch 9d) earlier in main.do invocation order.
> 
> INPUTS (verified via grep on file body)
>     $datadir_clean/calschls/staff/staff`year'  (CHAIN read across {1516,1617}; from renamedata batch 9d)
> 
> OUTPUTS (CANONICAL per ADR-0021 sandbox; verified via grep on file body)
>     $datadir_clean/calschls/qoiclean/staff/staffqoiclean`year'
>     $logdir/data_prep/qoiclean/staff/staffqoiclean1617_1516.smcl (via log using)
>     $logdir/data_prep/qoiclean/staff/staffqoiclean1617_1516.smcl + $logdir/data_prep/qoiclean/staff/staffqoiclean1617_
> 1516.log (translate)
> 
> RELOCATION (per plan v3 §3.3 step 9 batch 9e, applied 2026-05-08)
>     Source: caschls/do/build/buildanalysisdata/qoiclean/staff/staffqoiclean1617_1516.do
>     Path repointing applied (script-based methodology):
>       $projdir/log/build/buildanalysisdata/qoiclean/<sub>/<x>.smcl
>         -> $logdir/<x>.smcl  (CANONICAL — flattened from nested predecessor structure)
>       $projdir/dta/buildanalysisdata/qoiclean/<sub>/<x>
>         -> $datadir_clean/calschls/qoiclean/<sub>/<x>  (CANONICAL chain output)
>       $clndtadir/<sub>/<x> (read) -> $datadir_clean/calschls/<sub>/<x>
>         (CHAIN read; produced by renamedata batch 9d in same Stata session)
>       translate (single-line ABS form) -> $logdir/<x> (CANONICAL)
> 
> REFERENCES
>     ADRs:   0021 (sandbox; description convention)
>     Plan:   v3 §3.3 step 9 batch 9e (final batch of Step 9)
>     Sister files (this batch): 9 other qoiclean files (parent×4, secondary×3, staff×3)
> 
> ORIGINAL HEADER preserved verbatim below.
> ------------------------------------------------------------------------------*/
. 
. 
. ********************************************************************************
. /* clean staff 1617 survey questions of interest and generate analysis vars
> such as pct disagree/agree etc. */
. ********************************************************************************
. ********************************************************************************
. *************** written by Che Sun. Email: ucsun@ucdavis.edu ********************
. ********************************************************************************
. cap log close staffqoiclean1617_1516

. clear all

. set more off

. set varabbrev off, perm //set variable abbreviation permanently off
(set varabbrev preference recorded)

. 
. * --- output-directory prep (CANONICAL) ---------------------------------------
. cap mkdir "$logdir"

. cap mkdir "$logdir/data_prep"

. cap mkdir "$logdir/data_prep/qoiclean"

. cap mkdir "$logdir/data_prep/qoiclean/staff"

. cap mkdir "$datadir_clean"

. cap mkdir "$datadir_clean/calschls"

. cap mkdir "$datadir_clean/calschls/qoiclean"

. cap mkdir "$datadir_clean/calschls/qoiclean/staff"

. 
. log using "$logdir/data_prep/qoiclean/staff/staffqoiclean1617_1516.smcl", replace text name(staffqoiclean1617_1516)
(file
    /home/research/ca_ed_lab/projects/common_core_va/consolidated/log/data_prep/qoiclean/staff/staffqoiclean1617_1516.
    > smcl not found)
------------------------------------------------------------------------------------------------------------------------
      name:  staffqoiclean1617_1516
       log:  /home/research/ca_ed_lab/projects/common_core_va/consolidated/log/data_prep/qoiclean/staff/staffqoiclean161
> 7_1516.smcl
  log type:  text
 opened on:  18 May 2026, 12:13:12

. 
. /* the code for cleaning 1516 and 1617 is exactly the same, so use the same code to clean them */
. local years `" "1516" "1617" "'

. 
. foreach year of local years {
  2.   use $datadir_clean/calschls/staff/staff`year', clear
  3. 
.   /* Note: 1617 dataset does not have qoi 24 and 64
>   The qoi in this dataset are qoi 10 20 41 44 87 98 103-105 109 111 112 128*/
. 
.   keep cdscode q10 q20 q42 q72 q113 q66 q44 q45 q46 q50 q52 q53 hpdcs13 //keep questions of interest
  4. 
.   //delete all value labels not associated with variables
.   labdu , delete
  5.   //rename questions of interest using question numbers in 1819 as standard
.   /* rename the later questions to avoid var name conflict */
.   rename q44 q103
  6.   elabel rename q44 q103
  7.   rename q45 q104
  8.   elabel rename q45 q104
  9.   rename q46 q105
 10.   elabel rename q46 q105
 11.   rename q50 q109
 12.   elabel rename q50 q109
 13.   rename q52 q111
 14.   elabel rename q52 q111
 15.   rename q53 q112
 16.   elabel rename q53 q112
 17.   rename hpdcs13 q128
 18.   elabel rename hpdcs13 q128
 19. 
.   rename q42 q41
 20.   elabel rename q42 q41
 21.   rename q72 q44
 22.   elabel rename q72 q44
 23.   rename q113 q87
 24.   elabel rename q113 q87
 25.   rename q66 q98
 26.   elabel rename q66 q98
 27. 
.   /* Note: 1617 dataset does not have qoi 24 and 64 */
.   foreach i of numlist 10 20 41 44 87 98 103/105 109 111 112 128 {
 28.     rename q`i' qoi`i'
 29.     elabel rename q`i' qoi`i' //rename the value labels to be consistent with var name change
 30.   }
 31. 
.   /* count the total number of responses in each school */
.   sort cdscode
 32.   by cdscode: gen totalresp = _N
 33.   label var totalresp "total number of responses at each school including missing"
 34. 
. 
. 
.   ***************************** clean qoi 10 20 44 87 ****************************
.   /* value labels for qoi 10 20 41 44 87:
>   1 strongly agree
>   2 agree
>   3 disagree
>   4 strongly disagree
>   5 not applicable
> 
>   value label for qoi41 in 1617 and 1516 is different from 1819 and 1718, but we can treat them equivalently:
>   1 nearly all adults
>   2 most adults
>   3 some adults
>   4 few adults
>   5 almost none
>   Here treat 1 and 2 as agree, 3 as not applicable, and 4-5 as disagree
> 
>   recode:
>   -2 strongly disagree
>   -1 disagree
>   0 not applicable
>   1 agree
>   2 strongly agree
>   */
. 
. 
.   /* recode qoi 10 20 44 87 */
.   foreach i of numlist 10 20 44 87 {
 35.     gen qoi`i'temp =.
 36.     replace qoi`i'temp = -2 if qoi`i' == 4
 37.     replace qoi`i'temp = -1 if qoi`i' == 3
 38.     replace qoi`i'temp =  0 if qoi`i' == 5
 39.     replace qoi`i'temp =  1 if qoi`i' == 2
 40.     replace qoi`i'temp =  2 if qoi`i' == 1
 41. 
.     drop qoi`i'
 42.     rename qoi`i'temp qoi`i'
 43.   }
 44. 
. 
.   /* recode qoi 41 in 1617 */
.   gen qoi41temp = .
 45.   replace qoi41temp = 3 - qoi41
 46. 
.   drop qoi41
 47.   rename qoi41temp qoi41
 48. 
. 
.   /* generate dummies for each response option */
.   foreach i of numlist 10 20 41 44 87 {
 49.     gen stragree`i' = 0
 50.     replace stragree`i' = 1 if qoi`i' == 2
 51. 
.     gen agree`i' = 0
 52.     replace agree`i' = 1 if qoi`i' == 1
 53. 
.     gen disagree`i' = 0
 54.     replace disagree`i' = 1 if qoi`i' == -1
 55. 
.     gen strdisagree`i' = 0
 56.     replace strdisagree`i' = 1 if qoi`i' == -2
 57. 
.     gen neither`i' = 0
 58.     replace neither`i' = 1 if qoi`i' == 0
 59. 
.     gen missing`i' = 0
 60.     replace missing`i' = 1 if missing(qoi`i')
 61.   }
 62. 
. 
. /* Note: include qoi 41 with the rest in creating statistics for agree/disagree after recoding of values
>   /<x> note: mean of qoi41 is not comparable to later years <x>
>   gen all41 = 0
>   replace all41 = 1 if qoi41 == 1
> 
>   gen most41 = 0
>   replace most41 = 1 if qoi41 == 2
> 
>   gen some41 = 0
>   replace some41 = 1 if qoi41 == 3
> 
>   gen few41 = 0
>   replace few41 = 1 if qoi41 == 4
> 
>   gen none41 = 0
>   replace none41 = 1 if qoi41 == 5
> 
>   gen missing41 = 0
>   replace missing41 = 1 if missing(qoi41)
>   */
. 
. 
. 
. 
.   ******************************* clean qoi128 ***********************************
.   /* change the values for each response option to bring it in line with above qois
>   and make it possible to compare averages with previous qois */
.   /* original value label for qoi128:
>   1 strongly agree
>   2 agree
>   3 neither agree nor disagree
>   4 disagree
>   5 strongly disagree
> 
>   recode:
>   -2 strongly disagree
>   -1 disagree
>   0 neither
>   1 agree
>   2 strongly agree */
.   gen qoi128temp =.
 63.   replace qoi128temp = 3 - qoi128
 64. 
.   drop qoi128
 65.   rename qoi128temp qoi128
 66. 
.   label drop qoi128 //delete the original qoi128 value label
 67.   label define qoi128 2 "Strongly agree" 1 "Agree" -1 "Disagree" -2 "Strongly disagree" 0 "Neither agree nor disagr
> ee"
 68.   label values qoi128 qoi128
 69. 
.   /* generate dummies for each response option in qoi128 */
.   gen stragree128 = 0
 70.   replace stragree128 = 1 if qoi128 == 2
 71. 
.   gen agree128 = 0
 72.   replace agree128 = 1 if qoi128 == 1
 73. 
.   gen disagree128 = 0
 74.   replace disagree128 = 1 if qoi128 == -1
 75. 
.   gen strdisagree128 = 0
 76.   replace strdisagree128 = 1 if qoi128 == -2
 77. 
.   gen neither128 = 0
 78.   replace neither128 = 1 if qoi128 == 0
 79. 
.   gen missing128 = 0
 80.   replace missing128 = 1 if missing(qoi128)
 81. 
. 
.   ****************************** clean qoi 98 ************************************
.   /* value lables for qoi 98:
>   1 insignificant problem
>   2 mild problem
>   3 moderate problem
>   4 severe problem
> 
>   recode:
>   -3 severe problem
>   -2 moderate problem
>   -1 mild problem
>   1 insignificant problem
>   */
. 
.   /* recode qoi 98 */
.   gen qoi98temp = .
 82.   replace qoi98temp = -3 if qoi98 == 4
 83.   replace qoi98temp = -2 if qoi98 == 3
 84.   replace qoi98temp = -1 if qoi98 == 2
 85.   replace qoi98temp =  1 if qoi98 == 1
 86. 
.   drop qoi98
 87.   rename qoi98temp qoi98
 88. 
.   gen insig98 = 0
 89.   replace insig98 = 1 if qoi98 == 1
 90. 
.   gen mild98 = 0
 91.   replace mild98 = 1 if qoi98 == -1
 92. 
.   gen moderate98 = 0
 93.   replace moderate98 = 1 if qoi98 == -2
 94. 
.   gen severe98 = 0
 95.   replace severe98 = 1 if qoi98 == -3
 96. 
.   gen missing98 = 0
 97.   replace missing98 = 1 if missing(qoi98)
 98. 
. 
.   ***************************clean qoi 103-105 109 111 112************************
.   /* value labels for qoi 103-105 109 111 112:
>   1 yes
>   2 no
>   3 not applicable
> 
>   recode:
>   1 no
>   0 not applicable
>   -1 yes
>   This is because no means don't need more support so it's good
>   yes is bad
>   */
. 
.   /* recode qoi 103-105 109 111 112 */
.   foreach i of numlist 103/105 109 111 112 {
 99.     replace qoi`i' = -1 if qoi`i' == 1
100.     replace qoi`i' =  0 if qoi`i' == 3
101.     replace qoi`i' =  1 if qoi`i' == 2
102.   }
103. 
.   foreach i of numlist 103/105 109 111 112 {
104.     gen yes`i' = 0
105.     replace yes`i' = 1 if qoi`i' == -1
106. 
.     gen no`i' = 0
107.     replace no`i' = 1 if qoi`i' == 1
108. 
.     gen notapp`i' = 0
109.     replace notapp`i' = 1 if qoi`i' == 0
110. 
.     gen missing`i' = 0
111.     replace missing`i' = 1 if missing(qoi`i')
112.   }
113. 
. 
. 
.   /* collapse the dataset, resulting dataset has mean for each qoi, total number of responses, and number of responses
>  for each option in each question */
.   collapse (mean) qoi* totalresp (sum) stragree* agree* disagree* strdisagree* neither* insig98 mild98 moderate98 seve
> re98 yes* no* missing*, by(cdscode)
114.   /* NOTE: no* includes notapp* and none*, including both in collapse will case name conflict error. This literally
>  took me an hour to debug. -__-*/
. 
. 
.   ************************ relabel all the vars **********************************
.   foreach i of numlist 10 20 41 44 87 98 103/105 109 111 112 128 {
115.     label var qoi`i' "mean of qoi`i'"
116.   }
117. 
.   label var totalresp "total number of responses in the school including missing"
118. 
.   /* rename the qoi vars to reflect they are now averages */
.   rename qoi* qoi*mean
119. 
.   /* label vars for the number of response for each option */
.   foreach i of numlist 10 20 41 44 87 98 103/105 109 111 112 128 {
120.     label var missing`i' "number of missing responses for qoi`i'"
121.   }
122. 
.   /* label the response options for 10 20 44 87  */
.   foreach i of numlist 10 20 44 87 128{
123.     label var strdisagree`i' "number of people choosing strongly disagree for qoi`i'"
124.     label var disagree`i' "number of people choosing disagree for qoi`i'"
125.     label var agree`i' "number of people choosing agree for qoi`i'"
126.     label var stragree`i' "number of people choosing strongly agree for qoi`i'"
127.     label var neither`i' "number of people choosing not applicable for qoi`i'"
128.   }
129. /*
>   /<x> label the response options for qoi41 <x>
>   label var all41 "number of people choosing nearly all adults for qoi41"
>   label var most41 "number of people choosing most adults for qoi41"
>   label var some41 "number of people choosing some adults for qoi41"
>   label var few41 "number of people choosing few adults for qoi41"
>   label var none41 "number of people choosing almost none for qoi41"
> 
>   /<x> label the response options for 128  <x>
>   foreach i of numlist 128 {
>     label var strdisagree`i' "number of people choosing strongly disagree for qoi`i'"
>     label var disagree`i' "number of people choosing disagree for qoi`i'"
>     label var agree`i' "number of people choosing agree for qoi`i'"
>     label var stragree`i' "number of people choosing strongly agree for qoi`i'"
>     label var neither`i' "number of people choosing neither agree nor disagree for qoi`i'"
>   } */
. 
.   /* label the response options for qoi98 */
.   label var insig98 "number of people choosing insignificant problem for qoi98"
130.   label var mild98 "number of people choosing mild problem for qoi98"
131.   label var moderate98 "number of people choosing moderate problem for qoi98"
132.   label var severe98 "number of people choosing severe problem for qoi98"
133. 
.   /* label the response options for qoi 103-105 109 111 112 */
.   foreach i of numlist 103/105 109 111 112 {
134.     label var yes`i' "number of people choosing yes for qoi`i'"
135.     label var no`i' "number of people choosing no for qoi`i'"
136.     label var notapp`i' "number of people choosing not applicable for qoi`i'"
137.   }
138. 
. 
.   ********************* generate percentage agree/disagree etc *******************
.   /* first, generate the net total responses for each question excluding missing */
.   foreach i of numlist 10 20 41 44 87 98 103/105 109 111 112 128 {
139.     gen nettotalresp`i' = totalresp - missing`i'
140.     label var nettotalresp`i' "net total responses for qoi`i' excluding missing "
141.   }
142. 
.   /* generate percentage agree/disagree for qoi 10 20 44 87 */
.   foreach i of numlist 10 20 41 44 87 128 {
143.     gen pctdisagree`i' = (strdisagree`i' + disagree`i')/nettotalresp`i'
144.     label var pctdisagree`i' "percent strongly disagree or disagree in qoi`i'"
145.     gen pctagree`i' = (stragree`i' + agree`i')/nettotalresp`i'
146.     label var pctagree`i' "percent strongly agree or agree in qoi`i'"
147.     gen pctneither`i' = neither`i'/nettotalresp`i'
148.     label var pctneither`i' "percent not applicable in qoi`i'"
149.   }
150. 
. /*
>   /<x> Note: treat all and most as agree, some few and none as disagree in qoi41 <x>
>   gen pctagree41 = (all41 + most41)/nettotalresp41
>   label var pctagree41 "percent all or most adults in qoi41, equivlent to agree"
>   gen pctdisagree41 = (some41 + few41 + none41)/nettotalresp41
>   label var pctdisagree41 "percent some, few, or none in qoi41, equivalent to disagree" */
. /*
>   /<x> generate percentage agree/disagree for qoi 128 <x>
>   foreach i of numlist 128 {
>     gen pctdisagree`i' = (strdisagree`i' + disagree`i')/nettotalresp`i'
>     label var pctdisagree`i' "percent strongly disagree or disagree in qoi`i'"
>     gen pctagree`i' = (stragree`i' + agree`i')/nettotalresp`i'
>     label var pctagree`i' "percent strongly agree or agree in qoi`i'"
>     gen pctneither`i' = neither`i'/nettotalresp`i'
>     label var pctneither`i' "percent not applicable in qoi`i'"
>   } */
. 
.   /* generate percentage small/big problem for qoi98 */
.   gen pctsmallprob98 = (insig98 + mild98)/nettotalresp98
151.   gen pctbigprob98 = (moderate98 + severe98)/nettotalresp98
152.   label var pctsmallprob98 "percentage insignificant or mild problem for qoi98"
153.   label var pctbigprob98 "percentage moderate or severe problem for qoi98"
154. 
.   /* generate percentage yes/no for qoi 103/105 109 111 112 */
.   foreach i of numlist 103/105 109 111 112 {
155.     gen pctyes`i' = yes`i'/nettotalresp`i'
156.     label var pctyes`i' "percentage answering yes for qoi`i'"
157.     gen pctno`i' = no`i'/nettotalresp`i'
158.     label var pctno`i' "percentage answering no for qoi`i'"
159.     gen pctnotapp`i' = notapp`i'/nettotalresp`i'
160.     label var pctnotapp`i' "percent not applicable in qoi`i'"
161.   }
162. 
.   /* generate a year var to prepare for constructing a panel */
.   gen year = `year'
163. 
.   label data "cleaned staff `year' survey questions of interest with percent disagree/agree etc."
164.   compress
165.   save $datadir_clean/calschls/qoiclean/staff/staffqoiclean`year', replace
166. 
. }
