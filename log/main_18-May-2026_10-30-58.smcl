. forvalues fall_year = `= `test_score_min_year' - 1' (1) `= `test_score_max_year' - 1' {
  2.         di "Fall Year = `fall_year'"
  3. 
.         local fall_year_stub = substr("`fall_year'", 3, 2)
  4. 
.         import delimited $vaprojdir/data/public_access/raw/cde/staffcred/StaffCred`fall_year_stub'.txt, delimiter(tab)
>  varnames(1) case(lower) stringcols(1 2) numericcols(3 4) encoding("utf-8") clear
  5.         desc, full
  6.         codebook
  7. 
.         label var academicyear "Academic Year"
  8. 
.         label var recid "Record ID"
  9. 
.         label def credential 10 "Full Credential"
 10.         label def credential 20 "University Intern", add
 11.         label def credential 30 "District Intern", add
 12.         label def credential 40 "Waiver-Requested", add
 13.         label def credential 50 "Provisional Internship Permit-Available", add
 14.         label def credential 60 "Short-term Staff Permit -Requested", add
 15.         label def credential 70 "Child Development or Children’s Center Permit", add
 16.         label def credential 80 "Emergency or Long-Term Emergency Permits", add
 17.         label def credential 85 "Limited Assignment Teaching Permit", add
 18.         label def credential 90 "Certificate of Clearance", add
 19.         label def credential 95 "Activity Supervisor Clearance Certificate", add
 20.         rename credentialtype credential
 21.         label val credential credential
 22.         label var credential "The type of credential issued to the staff member by CCTC"
 23. 
.         label def authorization 100 "Elementary/Self-Contained Classroom/Multiple Subject"
 24.         label def authorization 107 "Secondary – any single subject", add
 25.         label def authorization 110 "Agriculture", add
 26.         label def authorization 120 "Art", add
 27.         label def authorization 130 "Biology", add
 28.         label def authorization 140 "Biology (specialized)", add
 29.         label def authorization 150 "Business", add
 30.         label def authorization 160 "Chemistry", add
 31.         label def authorization 170 "Chemistry (specialized)", add
 32.         label def authorization 180 "English", add
 33.         label def authorization 190 "Foundational-Level General Science", add
 34.         label def authorization 200 "Foundational-Level Mathematics", add
 35.         label def authorization 210 "Geoscience", add
 36.         label def authorization 220 "Geoscience (specialized)", add
 37.         label def authorization 230 "Health Science", add
 38.         label def authorization 240 "Home Economics", add
 39.         label def authorization 250 "Industrial and Technology", add
 40.         label def authorization 260 "Languages Other Than English", add
 41.         label def authorization 270 "Life Science", add
 42.         label def authorization 280 "Mathematics", add
 43.         label def authorization 290 "Music", add
 44.         label def authorization 300 "Physical Education", add
 45.         label def authorization 310 "Physical Science", add
 46.         label def authorization 320 "Physics", add
 47.         label def authorization 330 "Physics (specialized)", add
 48.         label def authorization 340 "Social Science", add
 49.         label def authorization 350 "Career Technical Education/Vocational", add
 50.         label def authorization 360 "Adult Education", add
 51.         label def authorization 370 "English Language Development (ELD) ONLY", add
 52.         label def authorization 375 "English Language Development (ELD) AND Specially Designed Academic Instruction
>  in English (SDAIE)", add
 53.         label def authorization 380 "Primary Language Instruction (BCLAD or equivalents) and SDAIE and ELD", add
 54.         label def authorization 390 "Reading Specialist/Certificate", add
 55.         label def authorization 400 "Special Designated Subjects (driver education, driver training, ROTC, basic mi
> litary drill, Aviation flight, or ground instruction)", add
 56.         label def authorization 410 "Special Education", add
 57.         label def authorization 420 "Specially Designed Academic Instruction in English (SDAIE) ONLY", add
 58.         label def authorization 999 "No authorization found for specified credential and time period", add
 59.         rename authorizationtype authorization
 60.         label val authorization authorization
 61.         label var authorization "The specific authorization (s) included in the credential issued by the CCTC"
 62. 
.         label var filecreated "Date that the file was created"
 63. 
.         gen date_created = date(filecreated, "MDY")
 64.         format date_created %td
 65.         label var date_created "Date that the file was created"
 66.         drop filecreated
 67. 
.         gen year = `fall_year' + 1
 68.         label var year "Year of Spring Semester"
 69. 
.         order year recid credential authorization
 70.         sort year recid credential authorization
 71.         compress
 72.         label data "California Department of Education Spring `=`fall_year' + 1' Staff Credential Records"
 73.         save $datadir_clean/cde/staffcred/staffcred_`=`fall_year' + 1'_clean.dta, replace
 74. }
