. foreach version in v1 v2 {
  2.   *******************************************
.   * Base test score sample
.   *******************************************
.   local create_b = 1
  3.   if `create_b' == 1 {
  4.     include $consolidated_dir/do/samples/create_va_sample.doh
  5. 
.     compress
  6.     tempfile va_dataset
  7.     save `va_dataset'
  8. 
.     // 11th grade sample
.     include $consolidated_dir/do/samples/create_va_g11_sample_`version'.doh
  9. 
.     // merge on k12 postsecondary distances (helper relocated 2026-05-08 batc
> h 9c)
.     include $consolidated_dir/do/data_prep/k12_postsec_distance/merge_k12_pos
> tsec_dist.doh
 10. 
.     // merge on lag 2 ELA scores without dropping obs, to predict lag 1 ELA s
> core
.     include $consolidated_dir/do/samples/merge_lag2_ela.doh
 11. 
. 
. 
.     * Save temporary dataset
.     compress
 12.     label data "Base Test Score VA Sample"
 13. 
.     save "$datadir_clean/va_samples_`version'/score_b.dta", replace
 14.   }
 15. 
. 
.   *******************************************
.   * Test score sample with leave out prior scores
.   *******************************************
. 
.   /* Leave out scores:
>   1.    Spring 2015 cohort use 7th grade ELA (spring 2011)
> 
>   2.    Spring 2016 cohort use 7th grade ELA (spring 2012)
> 
>   3.    Spring 2017 cohort use 6th grade ELA (spring 2012)
> 
>   4.    Spring 2018 cohort use 6th grade ELA (spring 2013)
>   */
.   //loscore stands for leave out score
.   local create_l = 1
 16.   if `create_l' == 1 {
 17.     use "$datadir_clean/va_samples_`version'/score_b.dta", clear
 18. 
.     // do helper file to merge leave out scores
.     include $consolidated_dir/do/samples/merge_loscore.doh
 19. 
.     label data "Test Score VA Sample with Leave Out Scores"
 20. 
.     compress
 21.     save "$datadir_clean/va_samples_`version'/score_l.dta", replace
 22. 
.   }
 23. 
. 
.   *******************************************
.   * Test score sample with ACS controls
.   *******************************************
.   local create_a = 1
 24.   if `create_a' == 1 {
 25. 
.     // call do helper file to merge onto ACS controls. Be sure to specify cor
