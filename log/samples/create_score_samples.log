> _clean.dta
>                                           — restricted-access raw K12 scores
>       $vaprojdir/data/restricted_access/clean/k12_test_scores/k12_lag_test_sc
> ores_clean.dta
>       $vaprojdir/data/restricted_access/clean/k12_test_scores/k12_peer_test_s
> cores_clean.dta
