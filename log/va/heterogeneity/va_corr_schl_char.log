. foreach version in v1 v2 {
  2.     /* first merge VA estimates and school characteristics */
.     di "VA version: `version'"
  3. 
.     use $estimates_dir/va_cfr_all_`version'/va_est_dta/va_all.dta, clear 
  4.     merge m:1 cdscode using $vaprojdir/data/sch_char_2018.dta, nogen keep(
> 1 3)
  5. 
.     /* // standardize VA estimates into z score
>       foreach va of varlist va_* {
>         sum `va'
>         replace `va' = `va' - r(mean)
>         replace `va' = `va' / r(sd)
>       } */
. 
.     /* local char_vars charter prop_ecn_disadv enr_black_hisp_prop locale_coa
> rse */
. 
.     local b_sample_controls b 
  6.     local las_sample_controls las 
  7.     
. 
.     foreach va_outcome in ela math enr enr_2year enr_4year {
  8.         di "dependent var: `va_outcome'"
  9. 
. 
.         foreach sample in b las {
 10.             di "VA sample: `sample'"
 11. 
.             if "`sample'" == "las" {
 12.                 local peer _p
 13.                 local peer_yn "Y"
 14.             } 
 15.             else {
 16.                 local peer
 17.                 local peer_yn "N"
 18.             }
 19. 
.             foreach va_ctrl of local `sample'_sample_controls {
 20.             di "VA controls: `va_ctrl'"
 21. 
.             /* school level regs, no controls */
.                 foreach het_char of local factor_het_char {
 22.                     di "categorical variable: `het_char'"
 23.                     reg va_`va_outcome'_`sample'_sp_`va_ctrl'_ct i.`het_ch
> ar' ///
>                         , cluster(school_id)
 24. 
.                     estadd ysumm, mean 
 25.                     estimates save $estimates_dir/va_cfr_all_`version'/va_
> het/va_`va_outcome'_het_`het_char'_`sampl
> e'_sp_`va_ctrl'_ct`peer'.ster, replace
 26. 
.                 }
 27. 
.                 foreach het_char of local cont_het_char {
 28.                     di "continuous variables: `cont_het_char'"
 29.                     reg va_`va_outcome'_`sample'_sp_`va_ctrl'_ct `het_char
> ' ///
>                         , cluster(school_id)
 30. 
.                     estadd ysumm, mean
 31.                     estimates save $estimates_dir/va_cfr_all_`version'/va_
> het/va_`va_outcome'_het_`het_char'_`sampl
> e'_sp_`va_ctrl'_ct`peer'.ster, replace
 32. 
.                 }
 33. 
. 
.             }
 34.         }
 35. 
.     }
 36. 
. }
