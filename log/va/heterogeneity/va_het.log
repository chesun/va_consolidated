> !=. & va_enr_2year_las_sp_las_ct_p !=. & 
> va_enr_4year_las_sp_las_ct_p !=. & year==2018)
 18.     // calculate number of schools in the sample in each district
.     egen numsch=sum(have_test_lr), by(district)
 19.     // tag unique districts in the sample
.     egen tag=tag(district) if have_test_lr==1
 20.     gsort -tag -numsch enr_total cdscode
 21. 
.     // indicator for having 2 or more schools in the district
.     gen gr2 = (numsch >= 2)
 22.     // indicator for having 5 or more schools in the district
.     gen gr5 = (numsch >= 5)
 23.     // indictor for schools in the top 25 largest school districts
.     summ numsch if _n==25 
 24.     gen top25=(numsch>=(r(mean)-.000000001))
 25. 
.     list tag numsch district enr_total gr2 gr5 top25 if tag==1 & _n<=30
