  4.     merge 1:1 cdscode year using $vaprojdir/data/sch_char.dta, nogen keep(
>  3)
  5. 
.     // create category dummies for locale
.     gen suburb = (locale_coarse==2)
  6.     gen town = (locale_coarse==3)
  7.     gen rural = (locale_coarse==4)
  8. 
.     // create log enrollment
.     gen logenroll = ln(enr_total)
  9. 
.     // impute missing values
.     summ enr_black_hisp_prop prop_ecn_disadv locale_coarse logenroll fte_pupi
> l_pc fte_teach_pc new_teacher_prop
 10.     foreach var of varlist charter fte_pupil_pc fte_teach_pc new_teacher_p
> rop {
