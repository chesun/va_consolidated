. foreach version in v1 v2 {
  2.     di "VA version: `version'"
  3. 
.     use $estimates_dir/va_cfr_all_`version'/va_est_dta/va_all.dta, clear 
  4.     merge m:1 cdscode using $vaprojdir/data/sch_char_2018.dta, nogen keep(
> 1 3)
  5. 
. 
. 
.     foreach va_outcome in ela math enr enr_2year enr_4year {
  6.         di "VA outcome: `va_outcome'"
  7. 
.         foreach sample in b las {
  8.             di "VA sample: `sample'"
  9. 
.             if "`sample'" == "las" {
 10.                 local peer _p
 11.                 local peer_yn "Y"
 12.             } 
 13.             else {
 14.                 local peer
 15.                 local peer_yn "N"
 16.             }
 17.             foreach va_ctrl of local `sample'_sample_controls {
 18.                 di "VA controls: `va_ctrl'"
 19. 
.                 /* correlation between VA and continuous school chars */
.                 foreach het_char of local cont_het_char {
 20.                     corr va_`va_outcome'_`sample'_sp_`va_ctrl'_ct`peer' `h
> et_char'
 21.                     local cor_`va_outcome'_`sample'_sp_`va_ctrl'_ct`peer':
>  di %5.3f r(rho)
 22.                     /* scatter plot */
.                     binscatter va_`va_outcome'_`sample'_sp_`va_ctrl'_ct`peer'
>  `het_char' ///
>                         , ytitle("``va_outcome'_str' VA") xtitle("``het_char'
> _str'") ///
>                         yline(0) xline(0) ///
>                         note("Correlation Coefficient: `cor_`va_outcome'_`sam
> ple'_sp_`va_ctrl'_ct`peer''")
 23.                     graph export $figures_dir/va_cfr_all_`version'/va_het/
> va_`va_outcome'_scatter_`het_char'_`sampl
> e'_sp_`va_ctrl'_ct`peer'.pdf, replace
 24. 
.                 }
 25. 
. 
.                 /* kernel density for VA by categorical school chars */
. 
.                 // locale
.                 twoway ///
>                     (kdensity va_`va_outcome'_`sample'_sp_`va_ctrl'_ct`peer' 
> if locale_coarse == 1) ///
>                     (kdensity va_`va_outcome'_`sample'_sp_`va_ctrl'_ct`peer' 
> if locale_coarse == 2, lpattern(dash)) //
> /
>                     (kdensity va_`va_outcome'_`sample'_sp_`va_ctrl'_ct`peer' 
> if locale_coarse == 3, lpattern("-..")) /
> //
>                     (kdensity va_`va_outcome'_`sample'_sp_`va_ctrl'_ct`peer' 
> if locale_coarse == 4, lpattern(shortdash
> )) ///
>                     , xtitle("``va_outcome'_str' VA") ///
>                     title("Kernel Density by Locale") ///
>                     legend(label(1 "City") label(2 "Suburban") label(3 "Town"
> ) label(4 "Rural"))
 26.                     
.                 graph export $figures_dir/va_cfr_all_`version'/va_het/va_`va_
> outcome'_density_locale_`sample'_sp_`va_c
> trl'_ct`peer'.pdf, replace
 27. 
.                 // charter
.                 twoway ///
>                     (kdensity va_`va_outcome'_`sample'_sp_`va_ctrl'_ct`peer' 
> if charter == 0) ///
>                     (kdensity va_`va_outcome'_`sample'_sp_`va_ctrl'_ct`peer' 
> if charter == 1, lpattern("-..")) ///
>                     , ytitle("``va_outcome'_str' VA") ///
>                     title("Kernel Density by Charter Status") ///
>                     legend(label(1 "Non-Charter") label(2 "Charter"))
 28. 
.                 graph export $figures_dir/va_cfr_all_`version'/va_het/va_`va_
> outcome'_density_charter_`sample'_sp_`va_
> ctrl'_ct`peer'.pdf, replace
 29. 
.                 }
 30. 
.             }
 31.         }
 32.     }
