. //---------------------------------------------------------------------------
> ---
. // tables for spec test
. //---------------------------------------------------------------------------
> ---
. 
. foreach version in v1 v2 {
  2.   di "VA version: `version'"
  3.   cap mkdir "$tables_dir/va_cfr_all_`version'/spec_test"
  4. 
.   local append_macro replace
  5. 
.   foreach va_outcome in ela math enr enr_2year enr_4year {
  6.     di " VA va_outcome: `va_outcome'"
  7. 
.     use $estimates_dir/va_cfr_all_`version'/va_est_dta/va_`va_outcome'_s_sp_s
> ib1_ct.dta, clear
  8. 
.     sort school_id year
  9.     xtset school_id year
 10.     //calculate sd of va estimates
.     sum va_cfr_g11_`va_outcome'
 11.     local sd_va: di %4.3f = r(sd)
 12. 
.     // specification test without peer controls
.     estimates use $estimates_dir/va_cfr_all_`version'/spec_test/spec_`va_outc
> ome'_s_sp_sib1_ct.ster
 13.     test _b[va_cfr_g11_`va_outcome'] = 1
 14.     local p_spec: di %4.3f = r(p)
 15. 
.     regsave using $tables_dir/va_cfr_all_`version'/spec_test/spec_sib_lag.dta
