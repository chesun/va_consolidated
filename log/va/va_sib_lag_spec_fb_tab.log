. foreach version in v1 v2 {
  2.   di "VA version: `version'"
  3.   cap mkdir "$tables_dir/va_cfr_all_`version'/fb_test"
  4. 
.   local append_macro replace
  5. 
.   foreach va_outcome in ela math enr enr_2year enr_4year {
  6.     di " VA va_outcome: `va_outcome'"
  7. 
. 
.     // load va estimates for the VAm regression including fb var
.     estimates use $estimates_dir/va_cfr_all_`version'/vam/va_`va_outcome'_s_s
> p_sib1_ct_sib2_lv.ster
  8. 
.     // F test for leave out vars
.     test `sib_lag2_controls'
  9.     local f_stat: di %4.3f = r(F)
 10.     local prob_f: di %4.3f = r(p)
 11. 
. 
.     // forecast bias estimates
.     estimates use $estimates_dir/va_cfr_all_`version'/fb_test/fb_`va_outcome'
> _s_sp_sib1_ct_sib2_lv.ster
 12. 
.     regsave using $tables_dir/va_cfr_all_`version'/fb_test/fb_sib_lag.dta, //
> /
>       pval ci addlabel(f_stat_lovar, `f_stat', prob_f, `prob_f', ///
>       va_control, sib_lag1, fb_var, sib_lag2, va_sample, sib_lag, va_type, `v
> a_outcome', peer_controls, 0) `append_mac
> ro'
 13. 
. 
.     local append_macro append
 14. 
.   }
 15. 
.   use $tables_dir/va_cfr_all_`version'/fb_test/fb_sib_lag.dta, clear
 16.   drop if var == "_cons"
 17.   order va_sample va_control peer_controls coef ci_lower ci_upper
 18.   sort va_sample va_control peer_controls
 19.   save, replace
 20. }
