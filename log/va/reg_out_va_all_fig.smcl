. #delimit cr
delimiter now cr
. 
. 
. 
. // macros for different VA estimates to be used in each sample
. local b_sample_controls b bd

. local las_sample_controls b ls las bd lsd lasd

. 
. 
. foreach version in v1 v2 {
  2. 
.   //------------------------------------------------------------------------------
.   // assign non-heterogeneity regression coefficients to scalars
.   //------------------------------------------------------------------------------
. 
.   foreach sample in b las {
  3.     di "outcome sample: `sample'"
  4.     foreach control of local `sample'_sample_controls {
  5.       di "VA control: `control'"
  6.       foreach outcome in enr enr_2year enr_4year {
  7.         di "dependent var: `outcome'"
  8. 
.           // loop over VA estimates without peer and with peer controls
.           forvalues i = 1/2 {
  9.             if `i'==1 {
 10.               local peer
 11.             }
 12.             if `i'==2 {
 13.               local peer _p
 14.             }
 15.             di "peer controls in VA estimates (empty if no peer, _p if peer): `peer'"
 16.             //-------------------------------------------------------------
.             // regressions on single subject VA estimate
.             //-------------------------------------------------------------
.             foreach subject in ela math {
 17.               di "subject: `subject'"
 18. 
.               // estimate from outcome regs with base controls
.               est use $estimates_dir/va_cfr_all_`version'/reg_out_va/reg_`outcome'_va_`subject'_`sample'_sp_`control'_
> ct`peer'.ster
 19. 
.               tempname `outcome'_`subject'_`sample'_`control'`peer'
 20.               scalar ``outcome'_`subject'_`sample'_`control'`peer'' = _b[va_`subject'_`sample'_sp_`control'_ct`peer
> ']
 21. 
.               // estimates from outcome regs with matching controls as used in VA estimation
.               est use $estimates_dir/va_cfr_all_`version'/reg_out_va/reg_`outcome'_va_`subject'_`sample'_sp_`control'_
> ct`peer'_m.ster
 22.               tempname `outcome'_`subject'_`sample'_`control'`peer'_m
 23.               scalar ``outcome'_`subject'_`sample'_`control'`peer'_m' = _b[va_`subject'_`sample'_sp_`control'_ct`pe
> er']
 24.             }
 25. 
.           //-------------------------------------------------------------
.           // regressions on both subject VA estimate
.           //-------------------------------------------------------------
.           // estimate from outcome regs with base controls
.           est use $estimates_dir/va_cfr_all_`version'/reg_out_va/reg_`outcome'_va_ela_math_`sample'_sp_`control'_ct`pe
> er'.ster
 26.           foreach subject in ela math {
 27.             tempname `outcome'_`subject'_`sample'_`control'`peer'_b
 28.             scalar ``outcome'_`subject'_`sample'_`control'`peer'_b' = _b[va_`subject'_`sample'_sp_`control'_ct`peer
> ']
 29.           }
 30. 
.           // estimates from outcome regs with matching controls as used in VA estimation
.           est use $estimates_dir/va_cfr_all_`version'/reg_out_va/reg_`outcome'_va_ela_math_`sample'_sp_`control'_ct`pe
> er'_m.ster
 31.           foreach subject in ela math {
 32.             tempname `outcome'_`subject'_`sample'_`control'`peer'_b_m
 33.             scalar ``outcome'_`subject'_`sample'_`control'`peer'_b_m' = _b[va_`subject'_`sample'_sp_`control'_ct`pe
> er']
 34.           }
 35. 
.         }
 36.       }
 37.     }
 38.   }
 39. 
. 
. 
.   //------------------------------------------------------------------------------
.   // figures for single subject VA regression, heterogeneity by prior score decile
.   //------------------------------------------------------------------------------
.   * GATE: prior-score-decile heterogeneity. Single source of truth = $run_prior_score in
.   * do/settings.do. Producer (reg_out_va_all.do / reg_out_va_dk_all.do) and ALL consumers
.   * (this file + <x>_tab.do) MUST gate on the same global; a disabled producer otherwise leaves
.   * consumers reading missing .ster -> r(601). [2026-05-28]
.   if "$run_prior_score" != "0" {
 40.   foreach sample in b las {
 41.     di "outcome sample: `sample'"
 42.     foreach control of local `sample'_sample_controls {
 43.       di "VA control: `control'"
 44.       foreach outcome in enr enr_2year enr_4year {
 45.         di "dependent var: `outcome'"
 46.         foreach subject in ela math {
 47.           di "`subject' test score"
 48.           foreach prior_subject in ela math {
 49.             di "interaction with prior `prior_subject' score deciles"
 50. 
.             // loop over VA estimates without peer and with peer controls
.             forvalues i = 1/2 {
 51.               if `i'==1 {
 52.                 local peer
 53.                 local peer_str "without"
 54.               }
 55.               if `i'==2 {
 56.                 local peer _p
 57.                 local peer_str "with"
 58.               }
 59.               di "peer controls in VA estimates (empty if no peer, _p if peer): `peer'"
 60. 
.                 forvalues i = 1/2 {
 61.                   if `i'==1 {
 62.                     local match
 63.                     local match_str "base"
 64.                   }
 65.                   if `i'==2 {
 66.                     local match _m
 67.                     local match_str "matching"
 68.                   }
 69. 
.                   est use $estimates_dir/va_cfr_all_`version'/reg_out_va/het_reg_`outcome'_va_`subject'_x_prior_`prior
> _subject'_`sample'_sp_`control'_ct`peer'`match'.ster
 70. 
.                   // convert estimation results into a dataset
.                   parmest, norestore
 71. 
.                   // keep only the interaction parameters
.                   keep if strpos(parm, "prior_`prior_subject'_z_score_xtile#c.va_`subject'_`sample'_sp_`control'_ct`pe
> er'") != 0
 72. 
.                   // generate a var that is the decile number of the prior score, from 1 to 10
.                   gen xtile = subinstr(substr(parm, 1, strpos(parm, ".")-1), "b", "", .)
 73.                   // convert xtile var into a numeric var
.                   destring xtile, replace
 74. 
.                   // twoway graph 1) bar graph of coefficient estimates 2) rcap for 90% CI
.                   // draw horizontal yline at the coefficient estimate from regression with only the subject VA, no in
> teraction
.                   #delimit ;
delimiter now ;
.                   twoway
>                     (bar estimate xtile, color(%50))
>                     (rcap min95 max95 xtile, color(%50))
>                     , yline(`=``outcome'_`subject'_`sample'_`control'`peer'`match''', lcolor(%30))
>                     yline(0, lcolor(black%30))
>                     legend(off)
