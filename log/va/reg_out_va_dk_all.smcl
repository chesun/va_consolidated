. #delimit cr
delimiter now cr
. 
. 
. 
. // macros for different VA estimates to be used in each sample
. local b_sample_controls b

. local las_sample_controls b ls las

. 
. 
. foreach version in v1 v2 {
  2. 
.   foreach sample in b las {
  3.     // load outcome dataset
.     use $datadir_clean/va_samples_`version'/out_`sample', clear
  4. 
.     // merge on the DK VA estimates
.     foreach outcome in enr enr_2year enr_4year {
  5.       merge m:1 cdscode year using ///
>         $estimates_dir/va_cfr_all_`version'/va_est_dta/va_`outcome'_all.dta ///
>         , nogen keep(1 3) keepusing(va_*)
  6. 
.       // standardize VA estimates into z score
.       foreach va of varlist va_* {
  7.         sum `va'
  8.         replace `va' = `va' - r(mean)
  9.         replace `va' = `va' / r(sd)
 10.       }
 11.     }
 12. 
.     //merge on prior score quantiles calculated in the base sample
.     merge m:1 state_student_id using ///
>       $datadir_clean/sbac/prior_decile_original_sample.dta, keep(1 3)
 13. 
.     //----------------------------------------------------------------------------
.     // regress enrollment on DK VA, matching left and right hand side outcome
.     /*
>     1. base sample: base sample base control VA
>     2. kitchen sink sample:
>       kitchen sink sample base control VA
>       kitchen sink sample loscre + sibling control VA
>       kitchen sink sample kitchen sink control VA
> 
>       each of the above VA: with and without peer controls
>     */
.     //----------------------------------------------------------------------------
.     di "outcome sample: `sample'"
 14.     foreach outcome in enr enr_2year enr_4year {
 15.       di "dependent var: `outcome'"
 16.       foreach control of local `sample'_sample_controls {
 17.         di "VA control: `control'"
 18.         // loop over VA estimates without peer and with peer controls
.         forvalues i = 1/2 {
 19.           if `i'==1 {
 20.             local peer
 21.           }
 22.           if `i'==2 {
 23.             local peer _p
 24.           }
 25. 
.           di "peer controls in VA estimates (empty if no peer, _p if peer): `peer'"
 26. 
.           //-------------------------------------------------------------
.           // enrollment on DK VA, matching left and right hand side outcome
.           //-------------------------------------------------------------
. 
.           // only base controls in the regression
.           reg `outcome' va_dk_`outcome'_`sample'_sp_`control'_ct`peer' ///
>             i.year `b_controls' ///
>             , cluster(school_id)
 27. 
.           estadd ysumm, mean
 28. 
.           estimates save $estimates_dir/va_cfr_all_`version'/reg_out_va/reg_`outcome'_va_dk_`outcome'_`sample'_sp_`con
> trol'_ct`peer'.ster, replace
 29. 
.           // match controls to the VA estimation controls
.           if "`peer'"=="" {
 30.             reg `outcome' va_dk_`outcome'_`sample'_sp_`control'_ct`peer' ///
>               i.year ``control'_spec_controls' ///
>               , cluster(school_id)
 31. 
.               estadd ysumm, mean
 32.               estimates save $estimates_dir/va_cfr_all_`version'/reg_out_va/reg_`outcome'_va_dk_`outcome'_`sample'_
> sp_`control'_ct`peer'_m.ster, replace
 33.           }
 34.           if "`peer'"=="_p" {
 35.             reg `outcome' va_dk_`outcome'_`sample'_sp_`control'_ct`peer' ///
>               i.year ``control'_spec_controls' ///
>               `peer_`control'_controls' ///
>               , cluster(school_id)
 36. 
.               estadd ysumm, mean
 37.               estimates save $estimates_dir/va_cfr_all_`version'/reg_out_va/reg_`outcome'_va_dk_`outcome'_`sample'_
> sp_`control'_ct`peer'_m.ster, replace
 38.           }
 39. 
. 
.           //-------------------------------------------------------------
.           // heterogeneity by prior score decile
.           //-------------------------------------------------------------
. 
.           * GATE: prior-score-decile heterogeneity. Single source of truth = $run_prior_score in
.           * do/settings.do. Producer (reg_out_va_all.do / reg_out_va_dk_all.do) and ALL consumers
.           * (<x>_tab.do, <x>_fig.do) MUST gate on the same global; a disabled producer otherwise leaves
.           * consumers reading missing .ster -> r(601). [2026-05-28]
.           if "$run_prior_score" != "0" {
 40.           foreach prior_subject in ela math {
 41.             di "interaction with prior `prior_subject' score deciles"
 42. 
.             // only base controls in the regression
.             reg `outcome' ///
>               c.va_dk_`outcome'_`sample'_sp_`control'_ct`peer'#i.prior_`prior_subject'_z_score_xtile ///
>               i.year `b_controls' ///
>               , cluster(school_id)
 43. 
.             estadd ysumm, mean
 44.             estimates save $estimates_dir/va_cfr_all_`version'/reg_out_va/het_reg_`outcome'_va_dk_`outcome'_x_prior
> _`prior_subject'_`sample'_sp_`control'_ct`peer'.ster, replace
 45. 
.             // match controls to the VA estimation controls
.             if "`peer'"=="" {
 46.               reg `outcome' ///
>                 c.va_dk_`outcome'_`sample'_sp_`control'_ct`peer'#i.prior_`prior_subject'_z_score_xtile ///
>                 i.year ``control'_spec_controls' ///
>                 , cluster(school_id)
 47. 
.                 estadd ysumm, mean
 48.                 estimates save $estimates_dir/va_cfr_all_`version'/reg_out_va/het_reg_`outcome'_va_dk_`outcome'_x_p
> rior_`prior_subject'_`sample'_sp_`control'_ct`peer'_m.ster, replace
 49.             }
 50.             if "`peer'"=="_p" {
 51.               reg `outcome' ///
>                 c.va_dk_`outcome'_`sample'_sp_`control'_ct`peer'#i.prior_`prior_subject'_z_score_xtile ///
>                 i.year ``control'_spec_controls' ///
>                 `peer_`control'_controls' ///
>                 , cluster(school_id)
 52. 
.                 estadd ysumm, mean
 53.                 estimates save $estimates_dir/va_cfr_all_`version'/reg_out_va/het_reg_`outcome'_va_dk_`outcome'_x_p
> rior_`prior_subject'_`sample'_sp_`control'_ct`peer'_m.ster, replace
 54.             }
 55. 
. 
. 
.           }
 56.           } // end gate: $run_prior_score (DK prior-decile estimation)
 57. 
. 
. 
. 
.         }
 58.       }
 59.     }
 60. 
.   }
 61. 
. 
. 
. 
. 
. }
