.         do do/va/reg_out_va_all.do                     // regress postsec outcomes on score VA + heterogeneity (prior 
> decile gated off; race/sex/econ/charter/income); writes $estimates_dir/.../reg_out_va/
.         do do/va/reg_out_va_all_tab.do                 // paper-shipping CSV tables of outcome-VA regressions; writes 
> $tables_dir/.../reg_out_va/
