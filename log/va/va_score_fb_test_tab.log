. foreach version in v1 v2 {
  2.   di "VA version: `version'"
  3. 
.   foreach subject in ela math {
  4.     di "subject: `subject'"
  5.     local append_macro replace
  6. 
.     foreach va_ctrl of local va_controls_for_fb {
  7.       di "VA regression controls: `va_ctrl'"
  8. 
.       foreach fb_var of local `va_ctrl'_ctrl_leave_out_vars {
  9.         di "Forecast bias leave out var: `fb_var'"
 10. 
.         foreach sample of local `fb_var'_fb_`va_ctrl'_samples {
 11.           di "sample: `sample'"
 12. 
. 
.           ****** calculating F stats for leave out vars
.           // replace macro if fb leave out var is sibling college dummy, can 
> only test 1.var
.           if "`fb_var'" == "s" {
 13.             local s_controls    1.has_older_sibling_enr_2year   1.has_olde
> r_sibling_enr_4year
 14.           }
 15.           if "`fb_var'" == "ls" {
 16.             local ls_controls `l_controls' 1.has_older_sibling_enr_2year  
>       1.has_older_sibling_enr_4year
 17.           }
 18.           if "`fb_var'" == "as" {
 19.             local as_controls `a_controls' 1.has_older_sibling_enr_2year  
>       1.has_older_sibling_enr_4year
 20.           }
 21.           if "`fb_var'" == "las" {
 22.             local las_controls `l_controls' `a_controls' 1.has_older_sibli
> ng_enr_2year  1.has_older_sibling_enr_4ye
> ar
 23.           }
 24. 
.           // load va estimates for the VAm regression including fb var withou
> t peer controls
.           estimates use $estimates_dir/va_cfr_all_`version'/vam/va_`subject'_
> `sample'_sp_`va_ctrl'_ct_`fb_var'_lv.ster
 25.           // F test for leave out vars
.           test ``fb_var'_controls'
 26.           local f_stat: di %4.3f = r(F)
 27.           local prob_f: di %4.3f = r(p)
 28. 
.           // load va estimates for the VAm regression including fb var with p
> eer controls
.           estimates use $estimates_dir/va_cfr_all_`version'/vam/va_p_`subject
> '_`sample'_sp_`va_ctrl'_ct_`fb_var'_lv.st
> er
 29.           // F test for leave out vars
.           test ``fb_var'_controls'
 30.           local f_stat_peer: di %4.3f = r(F)
 31.           local prob_f_peer: di %4.3f = r(p)
 32. 
.           // regression estimates without peer controls
.           estimates use $estimates_dir/va_cfr_all_`version'/fb_test/fb_`subje
> ct'_`sample'_sp_`va_ctrl'_ct_`fb_var'_lv.
> ster
 33. 
.           // output estimates to dta dataset
.           regsave using "$tables_dir/va_cfr_all_`version'/fb_test/fb_`subject
> '_all.dta", ///
>             pval ci addlabel(f_stat_lovar, `f_stat', prob_f, `prob_f', ///
>             va_control, `va_ctrl', fb_var, `fb_var', va_sample, `sample', va_
> type, `subject', peer_controls, 0, predic
> ted_score, 0) `append_macro'
 34. 
. 
.           // regression estimates with peer controls
.           estimates use $estimates_dir/va_cfr_all_`version'/fb_test/fb_p_`sub
> ject'_`sample'_sp_`va_ctrl'_ct_`fb_var'_l
> v.ster
 35. 
.           // output estimates to dta dataset
.           regsave using "$tables_dir/va_cfr_all_`version'/fb_test/fb_`subject
> '_all.dta", ///
>             pval ci addlabel(f_stat_lovar, `f_stat_peer', prob_f, `prob_f_pee
> r', ///
>             va_control, `va_ctrl', fb_var, `fb_var', va_sample, `sample', va_
> type, `subject', peer_controls, 1, predic
> ted_score, 0) append
 36. 
. 
.             // load VA estimates for VAM regression including fb var and pred
> icted score as controls without peer cont
> rols
.             * NOTE: predicted-prior-score reads are LEGACY ($vaprojdir/...); 
> Step 11 deferred (exploratory).
.             estimates use $vaprojdir/estimates/va_cfr_all_`version'/vam/predi
> cted_prior_score/va_`subject'_`sample'_sp
> _`va_ctrl'_ct_`fb_var'_lv.ster
 37.             // F test for leave out vars
.             test ``fb_var'_controls'
 38.             local f_stat_hatscore: di %4.3f = r(F)
 39.             local prob_f_hatscore: di %4.3f = r(p)
 40. 
.             // load va estimates for the VAm regression including fb var with
>  peer controls and predicted score as con
> trols
.           estimates use $vaprojdir/estimates/va_cfr_all_`version'/vam/predict
> ed_prior_score/va_p_`subject'_`sample'_sp
> _`va_ctrl'_ct_`fb_var'_lv.ster
 41.           // F test for leave out vars
.           test ``fb_var'_controls'
 42.           local f_stat_hatscore_peer: di %4.3f = r(F)
 43.           local prob_f_hatscore_peer: di %4.3f = r(p)
 44. 
.             ***** regressione estimates without peer controls, using predicte
> d scores as controls
.             estimates use $vaprojdir/estimates/va_cfr_all_`version'/fb_test/p
> redicted_prior_score/fb_`subject'_`sample
> '_sp_`va_ctrl'_ct_`fb_var'_lv.ster
 45.             // output estimates to dta dataset
.             regsave using "$tables_dir/va_cfr_all_`version'/fb_test/fb_`subje
> ct'_all.dta", ///
>               pval ci addlabel(f_stat_lovar, `f_stat_hatscore', prob_f, `prob
> _f_hatscore', ///
>               va_control, `va_ctrl', fb_var, `fb_var', va_sample, `sample', v
> a_type, `subject', peer_controls, 0, pred
> icted_score, 1) append
 46. 
.             ***** regressione estimates with peer controls, using predicted s
> cores as controls
.             estimates use $vaprojdir/estimates/va_cfr_all_`version'/fb_test/p
> redicted_prior_score/fb_p_`subject'_`samp
> le'_sp_`va_ctrl'_ct_`fb_var'_lv.ster
 47.             // output estimates to dta dataset
.             regsave using "$tables_dir/va_cfr_all_`version'/fb_test/fb_`subje
> ct'_all.dta", ///
>               pval ci addlabel(f_stat_lovar, `f_stat_hatscore_peer', prob_f, 
> `prob_f_hatscore_peer', ///
>               va_control, `va_ctrl', fb_var, `fb_var', va_sample, `sample', v
> a_type, `subject', peer_controls, 1, pred
> icted_score, 1) append
 48. 
.           local append_macro append
 49. 
. 
.         }
 50.       }
 51.     }
 52. 
.     use "$tables_dir/va_cfr_all_`version'/fb_test/fb_`subject'_all.dta", clea
> r
 53.     label var f_stat_lovar "F statistic for leave out variables"
 54.     label var prob_f "P value from F test for leave out vars"
 55.     label var fb_var "Leave out vars for forecast bias test"
 56.     label var va_type "VA outcome var"
 57.     label var va_control "Controls in VA estimation"
 58.     label var va_sample "Sample used in VA estimation"
 59.     label var peer_controls "Corresponding Peer Controls"
 60.     label var predicted_score "Using predicted ELA score as controls"
 61. 
.     drop if var == "_cons"
 62.     order va_sample va_control fb_var peer_controls coef ci_lower ci_upper
 63.     sort va_sample fb_var va_control peer_controls
 64.     save, replace
 65.   }
 66. 
. }
