> _dir/.../reg_out_va_dk/
.         log on master
.         di as text "  [OK]  do/va/reg_out_va_dk_all_tab.do"
.         log off master
.         log on master
.         di as text "  [RUN] do/va/reg_out_va_dk_all_fig.do"
.         log off master
