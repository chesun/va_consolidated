.         log off master
.         do do/va/va_corr.do            // diagnostic: print correlation matrix of VA estimates across 8 spec combinati
> ons; output to log only (no .dta/.csv)
.         log on master
.         di as text "  [OK]  do/va/va_corr.do"
.         log off master
.         log on master
.         di as text "  [RUN] do/va/prior_decile_original_sample.do"
.         log off master
