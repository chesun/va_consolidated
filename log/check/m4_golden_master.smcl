. * -- ster comparison: load both, compare e(b) + sqrt(diag(e(V))) --------------
. capture program drop cap_compare_ster

. program define cap_compare_ster, rclass
  1.     args pred_path cons_path
  2. 
.     * Load predecessor estimates
.     capture estimates use "`pred_path'"
  3.     if _rc {
  4.         local rc = _rc
  5.         return local status = "READ_ERROR"
  6.         return local details = "rc=`rc' loading pred .ster"
  7.         exit
  8.     }
  9.     tempname b1 V1
 10.     capture matrix `b1' = e(b)
 11.     local has_b1 = (_rc == 0)
 12.     capture matrix `V1' = e(V)
 13.     local has_V1 = (_rc == 0)
 14. 
.     if !`has_b1' {
 15.         return local status = "SKIP"
 16.         return local details = "pred .ster has no e(b) — non-estimation save"
 17.         exit
 18.     }
 19. 
.     local nc1 = colsof(`b1')
 20. 
.     * Load consolidated estimates
.     capture estimates use "`cons_path'"
 21.     if _rc {
 22.         local rc = _rc
 23.         return local status = "READ_ERROR"
 24.         return local details = "rc=`rc' loading cons .ster"
 25.         exit
 26.     }
 27.     tempname b2 V2
 28.     capture matrix `b2' = e(b)
 29.     local has_b2 = (_rc == 0)
 30.     capture matrix `V2' = e(V)
 31.     local has_V2 = (_rc == 0)
 32. 
.     if !`has_b2' {
 33.         return local status = "FAIL"
 34.         return local details = "cons .ster has no e(b) (pred had `nc1' coefs)"
 35.         exit
 36.     }
 37. 
.     local nc2 = colsof(`b2')
 38.     if `nc1' != `nc2' {
 39.         return local status = "FAIL"
 40.         return local details = "coef vector size mismatch: pred=`nc1' cons=`nc2'"
 41.         exit
 42.     }
 43. 
.     * Compare element-wise.  b is 1 x K row vector.
.     local max_b_diff  = 0
 44.     local max_se_diff = 0
 45.     forvalues k = 1/`nc1' {
 46.         local b1k = `b1'[1,`k']
 47.         local b2k = `b2'[1,`k']
 48.         if !missing(`b1k') & !missing(`b2k') {
 49.             local d = abs(`b1k' - `b2k')
 50.             if `d' > `max_b_diff' local max_b_diff = `d'
 51.         }
 52.         if `has_V1' & `has_V2' {
 53.             capture {
 54.                 local v1k = `V1'[`k',`k']
 55.                 local v2k = `V2'[`k',`k']
 56.                 if !missing(`v1k') & !missing(`v2k') & `v1k' >= 0 & `v2k' >= 0 {
 57.                     local se1 = sqrt(`v1k')
 58.                     local se2 = sqrt(`v2k')
 59.                     local sed = abs(`se1' - `se2')
 60.                     if `sed' > `max_se_diff' local max_se_diff = `sed'
 61.                 }
 62.             }
 63.         }
 64.     }
 65. 
.     * Tolerance per replication-protocol.md §3.  Diff magnitudes (max|db|,
.     * max|dSE|) are summary-class quantities and are reported in the `details`
.     * string so offline triage can compare against the 0.01 / 0.05 tolerances
.     * without re-running on Scribe.  Also printed to the log for redundancy.
.     display as text "  [ster diag] max|db|=" %7.4f `max_b_diff' "  max|dSE|=" %7.4f `max_se_diff'
 66.     if (`max_b_diff' <= 0.01) & (`max_se_diff' <= 0.05) {
 67.         return local status = "PASS"
 68.         return local details = "coef and SE within tolerance (max|db|=`:di %7.4f `max_b_diff'' max|dSE|=`:di %7.4f 
> `max_se_diff'')"
 69.         exit
 70.     }
 71. 
.     return local status = "FAIL"
 72.     return local details = "max|db|=`:di %7.4f `max_b_diff'' max|dSE|=`:di %7.4f `max_se_diff''"
 73. end

