. forvalues i = 1/`npairs' {
  2.     di as text _n "--- [`lab_`i'']"
  3.     di as text "    pred: `pred_`i''"
  4.     di as text "    cons: `cons_`i''"
  5. 
.     capture use "`pred_`i''", clear
  6.     if _rc {
  7.         di as error "    predecessor load FAILED rc=" _rc
  8.         continue
  9.     }
 10.     local Np = _N
 11.     local Kp = c(k)
 12.     qui ds
 13.     local vp `r(varlist)'
 14. 
.     capture use "`cons_`i''", clear
 15.     if _rc {
 16.         di as error "    consolidated load FAILED rc=" _rc
 17.         continue
 18.     }
 19.     local Nc = _N
 20.     local Kc = c(k)
 21.     qui ds
 22.     local vc `r(varlist)'
 23. 
.     di as result "    obs:  pred=`Np'  cons=`Nc'  delta=" `Nc' - `Np'
 24.     di as result "    vars: pred=`Kp'  cons=`Kc'"
 25. 
.     local pred_only : list vp - vc
 26.     local cons_only : list vc - vp
 27.     local common    : list vp & vc
 28.     local n_po : word count `pred_only'
 29.     local n_co : word count `cons_only'
 30.     local n_cm : word count `common'
 31.     di as result "    vars only in PREDECESSOR (`n_po'): `pred_only'"
 32.     di as result "    vars only in CONSOLIDATED (`n_co'): `cons_only'"
 33. 
.     * If obs counts match, value-compare the common variables.
.     * CAVEAT: cf compares row-by-row — if reported diffs are large, rule out 
> a
.     *         sort-order difference before concluding data regression.
.     if `Np' == `Nc' & `n_cm' > 0 {
 34.         di as text "    obs counts match -> cf on `n_cm' common vars:"
 35.         capture use "`pred_`i''", clear
 36.         if _rc {
 37.             di as error "    predecessor RE-load FAILED rc=" _rc " -> skip
>  cf (would self-compare consolidated)"
 38.             continue
 39.         }
 40.         capture noisily cf `common' using "`cons_`i''"
 41.         di as result "    cf rc=" _rc " (0 = all common-var values identic
> al)"
 42.     }
 43.     else if `Np' != `Nc' {
 44.         di as result "    obs counts DIFFER -> skip cf; triage the N delta
>  (intended ADR change vs regression)"
 45.     }
 46. }

