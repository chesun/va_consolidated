. forvalues i = 1/`npairs' {c -(}
{txt}  2{com}.     di as text _n "--- [`lab_`i'']"
{txt}  3{com}.     di as text "    pred: `pred_`i''"
{txt}  4{com}.     di as text "    cons: `cons_`i''"
{txt}  5{com}. 
.     capture use "`pred_`i''", clear
{txt}  6{com}.     if _rc {c -(}
{txt}  7{com}.         di as error "    predecessor load FAILED rc=" _rc
{txt}  8{com}.         continue
{txt}  9{com}.     {c )-}
{txt} 10{com}.     local Np = _N
{txt} 11{com}.     local Kp = c(k)
{txt} 12{com}.     qui ds
{txt} 13{com}.     local vp `r(varlist)'
{txt} 14{com}. 
.     capture use "`cons_`i''", clear
{txt} 15{com}.     if _rc {c -(}
{txt} 16{com}.         di as error "    consolidated load FAILED rc=" _rc
{txt} 17{com}.         continue
{txt} 18{com}.     {c )-}
{txt} 19{com}.     local Nc = _N
{txt} 20{com}.     local Kc = c(k)
{txt} 21{com}.     qui ds
{txt} 22{com}.     local vc `r(varlist)'
{txt} 23{com}. 
.     di as result "    obs:  pred=`Np'  cons=`Nc'  delta=" `Nc' - `Np'
{txt} 24{com}.     di as result "    vars: pred=`Kp'  cons=`Kc'"
{txt} 25{com}. 
.     local pred_only : list vp - vc
{txt} 26{com}.     local cons_only : list vc - vp
{txt} 27{com}.     local common    : list vp & vc
{txt} 28{com}.     local n_po : word count `pred_only'
{txt} 29{com}.     local n_co : word count `cons_only'
{txt} 30{com}.     local n_cm : word count `common'
{txt} 31{com}.     di as result "    vars only in PREDECESSOR (`n_po'): `pred_only'"
{txt} 32{com}.     di as result "    vars only in CONSOLIDATED (`n_co'): `cons_only'"
{txt} 33{com}. 
.     * If obs counts match, value-compare the common variables.
.     * CAVEAT: cf compares row-by-row — if reported diffs are large, rule out a
.     *         sort-order difference before concluding data regression.
.     if `Np' == `Nc' & `n_cm' > 0 {c -(}
{txt} 34{com}.         di as text "    obs counts match -> cf on `n_cm' common vars:"
{txt} 35{com}.         capture use "`pred_`i''", clear
{txt} 36{com}.         if _rc {c -(}
{txt} 37{com}.             di as error "    predecessor RE-load FAILED rc=" _rc " -> skip cf (would self-compare consolidated)"
{txt} 38{com}.             continue
{txt} 39{com}.         {c )-}
{txt} 40{com}.         capture noisily cf `common' using "`cons_`i''"
{txt} 41{com}.         di as result "    cf rc=" _rc " (0 = all common-var values identical)"
{txt} 42{com}.     {c )-}
{txt} 43{com}.     else if `Np' != `Nc' {c -(}
{txt} 44{com}.         di as result "    obs counts DIFFER -> skip cf; triage the N delta (intended ADR change vs regression)"
{txt} 45{com}.     {c )-}
{txt} 46{com}. {c )-}

