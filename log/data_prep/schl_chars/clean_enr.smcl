. *****************
. * Begin Do File *
. *****************
. forvalues fall_year = `= `test_score_min_year' - 1' (1) `= `test_score_max_year' - 1' {
  2.         di "Fall Year = `fall_year'"
  3. 
.         local fall_year_stub = substr("`fall_year'", 3, 2)
  4. 
.         import delimited $vaprojdir/data/public_access/raw/cde/enr/filesenr`fall_year_stub'.asp.txt, delimiter(tab) va
> rnames(1) stringcols(1) encoding(ISO-8859-1) clear
  5.         desc, full
  6.         codebook
  7. 
.         rename cds_code cdscode
  8.         label var cdscode "CDS Code"
  9.         label var county "County"
 10.         label var district "District"
 11.         label var school "School"
 12. 
.         rename ethnic ethnicity
 13.         label def ethnicity 0 "Not reported"
 14.         label def ethnicity 1 "American Indian or Alaska Native, Not Hispanic", add
 15.         label def ethnicity 2 "Asian, Not Hispanic", add
 16.         label def ethnicity 3 "Pacific Islander, Not Hispanic", add
 17.         label def ethnicity 4 "Filipino, Not Hispanic", add
 18.         label def ethnicity 5 "Hispanic or Latino", add
 19.         label def ethnicity 6 "African American, not Hispanic", add
 20.         label def ethnicity 7 "White, not Hispanic", add
 21.         label def ethnicity 9 "Two or More Races, Not Hispanic", add
 22.         label val ethnicity ethnicity
 23.         label var ethnicity "Racial/ethnic designation"
 24. 
.         label def race 1 "American Indian or Alaska Native"
 25.         label def race 2 "Asian", add
 26.         label def race 5 "Hispanic or Latino", add
 27.         label def race 6 "Black or African American", add
 28.         label def race 7 "White", add
 29.         label def race 8 "Two or More Races", add
 30.         //gen varname:lblname = []
.         gen race:race = 1 if ethnicity==1
 31.         replace race = 2 if inlist(ethnicity, 2, 3, 4)
 32.         replace race = 5 if ethnicity==5
 33.         replace race = 6 if ethnicity==6
 34.         replace race = 7 if ethnicity==7
 35.         replace race = 8 if ethnicity==9
 36.         label var race "Race"
 37. 
.         label def male 1 "Male" 0 "Female"
 38.         gen male:male = 1 if gender=="M"
 39.         replace male = 0 if gender=="F"
 40.         replace male = . if mi(gender)
 41.         label var male "Male"
 42.         drop gender
 43. 
.         label var kdgn "Students enrolled in kindergarten"
 44. 
.         label var gr_1 "Students enrolled in grade one"
 45. 
.         label var gr_2 "Students enrolled in grade two"
 46. 
.         label var gr_3 "Students enrolled in grade three"
 47. 
.         label var gr_4 "Students enrolled in grade four"
 48. 
.         label var gr_5 "Students enrolled in grade five"
 49. 
.         label var gr_6 "Students enrolled in grade six"
 50. 
.         label var gr_7 "Students enrolled in grade seven"
 51. 
.         label var gr_8 "Students enrolled in grade eight"
 52. 
.         label var ungr_elm "Students enrolled in ungraded elementary classes in grades kindergarten through eight"
 53. 
.         label var gr_9 "Students enrolled in grade nine"
 54. 
.         label var gr_10 "Students enrolled in grade ten"
 55. 
.         label var gr_11 "Students enrolled in grade eleven"
 56. 
.         label var gr_12 "Students enrolled in grade twelve"
 57. 
.         label var ungr_sec "Students enrolled in ungraded secondary classes in grades nine through twelve"
 58. 
.         label var enr_total "Total school enrollment for fields Kindergarten (KDGN) through grade twelve (GR_12) plus 
> ungraded elementary (UNGR_ELM) and ungraded secondary classes (UNGR_SEC). Adults in kindergarten through grade twelve 
> programs are not included."
 59. 
.         label var adult "Adults enrolled in kindergarten through grade twelve programs. This data does not include adu
> lt education students."
 60. 
.         gen year = `fall_year' + 1
 61.         label var year "Year of Spring Semester"
 62. 
.         order cdscode year county district school ethnicity race male
 63.         sort cdscode year county district school ethnicity race male
 64.         compress
 65.         label data "California Department of Education Spring `=`fall_year' + 1' School Enrollment"
 66.         save $datadir_clean/cde/enr/enr_`=`fall_year' + 1'_clean.dta, replace
 67. }
