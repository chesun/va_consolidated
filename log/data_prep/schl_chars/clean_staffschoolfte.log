  2.         di "Fall Year = `fall_year'"
  3. 
.         local fall_year_stub = substr("`fall_year'", 3, 2)
  4. 
.         import delimited $vaprojdir/data/public_access/raw/cde/staffschoolfte
> /StaffSchoolFTE`fall_year_stub'.txt, deli
> miter(tab) varnames(1) case(lower) stringcols(1 2 3 4) encoding("utf-8") clea
> r
  5.         desc, full
  6.         codebook
  7. 
.         label var academicyear "Academic Year"
  8. 
.         label var recid "Record ID"
  9. 
.         label var districtcode "District Code"
 10. 
.         label var schoolcode "School Code"
 11. 
.         gen cdscode = districtcode + schoolcode
 12.         label var cdscode "CDS Code"
 13. 
.         label var countyname "County Name"
 14. 
.         label var districtname "District Name"
 15. 
.         label var schoolname "School Name"
 16. 
.         label def job_classification 10 "Administrator"
 17.         label def job_classification 11 "Pupil services", add
 18.         label def job_classification 12 "Teacher", add
 19.         label def job_classification 25 "Non-certificated Administrator", 
> add
 20.         label def job_classification 26 "Charter School Non-certificated T
> eacher", add
 21.         label def job_classification 27 "Itinerant or Pull-Out/Push-In Tea
> cher", add
 22.         rename jobclassification job_classification
 23.         label val job_classification job_classification
 24.         label var job_classification "Educational Service Job Classificati
> on"
 25. 
.         label var stafftype "Type of staff assignment"
 26. 
.         label def staff_type 1 "Administrator"
 27.         label def staff_type 2 "Pupil services", add
 28.         label def staff_type 3 "Teacher", add
 29.         gen staff_type:staff_type = 1 if stafftype=="A"
 30.         replace staff_type = 2 if stafftype=="P"
 31.         replace staff_type = 3 if stafftype=="T"
 32. 
.         label var fte "Full-time equivalent (FTE) teaching duties"
 33. 
.         label var filecreated "Date that the file was created"
 34. 
.         gen date_created = date(filecreated, "MDY")
 35.         format date_created %td
 36.         label var date_created "Date that the file was created"
 37.         drop filecreated
 38. 
.         gen year = `fall_year' + 1
 39.         label var year "Year of Spring Semester"
 40. 
.         order cdscode year recid job_classification fte
 41.         sort cdscode year recid job_classification fte
 42.         compress
 43.         label data "California Department of Education Spring `=`fall_year
> ' + 1' Staff School FTE"
 44.         save $datadir_clean/cde/staffschoolfte/staffschoolfte_`=`fall_year
> ' + 1'_clean.dta, replace
 45. }
