. forvalues fall_year = 2014 (1) 2014 {
  2.         di "Fall Year = `fall_year'"
  3. 
.         local fall_year_stub = substr("`fall_year'", 3, 2)
  4. 
.         import delimited $vaprojdir/data/public_access/raw/cde/staffdemo/StaffDemo`fall_year_stub'.txt, delimiter(tab)
>  varnames(1) case(lower) stringcols(1 2 3) encoding("utf-8") clear
  5.         desc, full
  6.         codebook
  7. 
.         label var academicyear "Academic Year"
  8. 
.         label var recid "Record ID"
  9. 
.         label var districtcode "District Code"
 10. 
.         label var countyname "County name"
 11. 
.         label var districtname "District name"
 12. 
.         label var gendercode "Gender"
 13. 
.         label def male 1 "Male" 0 "Female"
 14.         gen male:male = 1 if gendercode=="M"
 15.         replace male = 0 if gendercode=="F"
 16.         replace male = . if mi(gendercode)
 17.         label var male "Male"
 18.         drop gendercode
 19. 
.         label var educationlevel "Staff member's highest educational level (honorary degrees not included)"
 20. 
.         label def education 1 "Doctorate"
 21.         label def education 2 "Master's degree plus 30 or more semester hours", add
 22.         label def education 3 "Master's degree", add
 23.         label def education 4 "Bachelor's degree plus 30 or more semester hours", add
 24.         label def education 5 "Bachelor's degree", add
 25.         label def education 6 "Less than bachelor's degree", add
 26.         label def education 7 "Not reported", add
 27.         label def education 8 "Special", add
 28.         label def education 9 "Fifth year within bachelor's degree", add
 29.         label def education 10 "Fifth year induction", add
 30.         label def education 11 "Fifth year", add
 31.         gen education:education = 1 if educationlevel=="D"
 32.         replace education = 8 if educationlevel=="S"
 33.         replace education = 2 if educationlevel=="V"
 34.         replace education = 3 if educationlevel=="M"
 35.         replace education = 9 if educationlevel=="U"
 36.         replace education = 10 if educationlevel=="Y"
 37.         replace education = 11 if educationlevel=="F"
 38.         replace education = 4 if educationlevel=="C"
 39.         replace education = 5 if educationlevel=="B"
 40.         replace education = 6 if educationlevel=="A"
 41.         replace education = 7 if educationlevel=="N"
 42.         replace education = . if mi(educationlevel)
 43. 
.         label def ethnicity 0 "Not Reported"
 44.         label def ethnicity 1 "American Indian or Alaska Native, not Hispanic", add
 45.         label def ethnicity 2 "Asian, not Hispanic", add
 46.         label def ethnicity 3 "Pacific Islander, not Hispanic", add
 47.         label def ethnicity 4 "Filipino, not Hispanic", add
 48.         label def ethnicity 5 "Hispanic or Latino", add
 49.         label def ethnicity 6 "African American, not Hispanic", add
 50.         label def ethnicity 7 "White, not Hispanic", add
 51.         label def ethnicity 9 "Two or More Races, not Hispanic", add
 52.         rename ethnicgroup ethnicity
 53.         label val ethnicity ethnicity
 54.         label var ethnicity "Staff member's racial/ethnic designation"
 55. 
.         label def race 1 "American Indian or Alaska Native"
 56.         label def race 2 "Asian", add
 57.         label def race 5 "Hispanic or Latino", add
 58.         label def race 6 "Black or African American", add
 59.         label def race 7 "White", add
 60.         label def race 8 "Two or More Races", add
 61.         gen race:race = 1 if ethnicity==1
 62.         replace race = 2 if inlist(ethnicity, 2, 3, 4)
 63.         replace race = 5 if ethnicity==5
 64.         replace race = 6 if ethnicity==6
 65.         replace race = 7 if ethnicity==7
 66.         replace race = 8 if ethnicity==9
 67.         label var race "Race"
 68. 
.         /*gen eth_american_indian = (race==1)
>         replace eth_american_indian = . if mi(race)
>         label var eth_american_indian "American Indian or Alaska Native"
> 
>         gen eth_asian = (race==2)
>         replace eth_asian = . if mi(race)
>         label var eth_asian "Asian"
> 
>         gen eth_hispanic = (race==5)
>         replace eth_hispanic = . if mi(race)
>         label var eth_hispanic "Hispanic or Latino"
> 
>         gen eth_black = (race==6)
>         replace eth_black = . if mi(race)
>         label var eth_black "Black or African American"
> 
>         gen eth_white = (race==7)
>         replace eth_white = . if mi(race)
>         label var eth_white "White"
> 
>         gen eth_biracial = (race==8)
>         replace eth_biracial = . if mi(race)
>         label var eth_biracial "Two or More Races"
> 
>         gen eth_other = inlist(race, 1, 8, .)
>         label var eth_other "Other Race"*/
. 
.         rename yearsteaching years_teaching
 69.         label var years_teaching "Total years of public and/or private educational service. Includes services in th
> is district, other districts, other states, and countries. Does not include substitute teaching or classified staff se
> rvice. The first year of service is counted as 1 year."
 70. 
.         rename yearsindistrict years_district
 71.         label var years_district "Total years of service in a certificated position in the district. The first year
>  of service is counted as 1 year."
 72. 
.         label var employmentstatuscode "Indicates whether the teacher's position is tenured, probationary, or long-ter
> m substitute or temporary employee"
 73. 
.         label def employment_status 1 "Long term substitute or temporary employee"
 74.         label def employment_status 2 "Probationary", add
 75.         label def employment_status 3 "Tenured", add
 76.         label def employment_status 4 "Other", add
 77.         gen employment_status:employment_status = 1 if employmentstatuscode=="L"
 78.         replace employment_status = 2 if employmentstatuscode=="P"
 79.         replace employment_status = 3 if employmentstatuscode=="T"
 80.         replace employment_status = 4 if employmentstatuscode=="O"
 81.         replace employment_status = . if mi(employmentstatuscode)
 82.         label var employment_status "Employment Status"
 83. 
.         rename fteteaching fte_teach
 84.         label var fte_teach "Full-time equivalent (FTE) teaching duties"
 85. 
.         rename fteadministrative fte_admin
 86.         label var fte_admin "FTE administrative duties"
 87. 
.         rename ftepupilservices fte_pupil
 88.         label var fte_pupil "FTE pupil services duties"
 89. 
.         egen fte = rowtotal(fte_teach fte_admin fte_pupil), missing
 90.         label var fte "Full-Time Equivalent"
 91. 
.         label var filecreated "Date that the file was created"
 92. 
.         gen date_created = date(filecreated, "MDY")
 93.         format date_created %td
 94.         label var date_created "Date that the file was created"
 95.         drop filecreated
 96. 
.         gen year = `fall_year' + 1
 97.         label var year "Year of Spring Semester"
 98. 
.         order districtcode year recid
 99.         sort districtcode year recid
100.         compress
101.         label data "California Department of Education Spring `=`fall_year' + 1' Staff Demographics Records"
102.         save $datadir_clean/cde/staffdemo/staffdemo_`=`fall_year' + 1'_clean.dta, replace
103. }
