. forvalues fall_year = 2015 (1) `= `test_score_max_year' - 1' {
  2.         di "Fall Year = `fall_year'"
  3. 
.         local fall_year_stub = substr("`fall_year'", 3, 2)
  4. 
.         import delimited $vaprojdir/data/public_access/raw/cde/staffdemo/StaffDemo`fall_year_stub'.txt, delimiter(tab)
>  varnames(1) case(lower) stringcols(1 2 3) encoding("utf-8") clear
  5.         desc, full
  6.         codebook
  7. 
.         label var academicyear "Academic Year"
  8. 
.         label var recid "Record ID"
  9. 
.         label var districtcode "District Code"
 10. 
.         label var countyname "County name"
 11. 
.         label var districtname "District name"
 12. 
.         label var gendercode "Gender"
 13. 
.         label def male 1 "Male" 0 "Female"
 14.         gen male:male = 1 if gendercode=="M"
 15.         replace male = 0 if gendercode=="F"
 16.         replace male = . if mi(gendercode)
 17.         label var male "Male"
 18.         drop gendercode
 19. 
.         label var age "The age of the staff member on Census Day"
 20. 
.         label var educationlevel "Staff member's highest educational level (honorary degrees not included)"
 21. 
.         label def education 1 "Doctorate"
 22.         label def education 2 "Master's degree plus 30 or more semester hours", add
 23.         label def education 3 "Master's degree", add
 24.         label def education 4 "Bachelor's degree plus 30 or more semester hours", add
 25.         label def education 5 "Bachelor's degree", add
 26.         label def education 6 "Less than bachelor's degree", add
 27.         label def education 7 "Not reported", add
 28.         label def education 8 "Special", add
 29.         label def education 9 "Fifth year within bachelor's degree", add
 30.         label def education 10 "Fifth year induction", add
 31.         label def education 11 "Fifth year", add
 32.         gen education:education = 1 if educationlevel=="D"
 33.         replace education = 8 if educationlevel=="S"
 34.         replace education = 2 if educationlevel=="V"
 35.         replace education = 3 if educationlevel=="M"
 36.         replace education = 9 if educationlevel=="U"
 37.         replace education = 10 if educationlevel=="Y"
 38.         replace education = 11 if educationlevel=="F"
 39.         replace education = 4 if educationlevel=="C"
 40.         replace education = 5 if educationlevel=="B"
 41.         replace education = 6 if educationlevel=="A"
 42.         replace education = 7 if educationlevel=="N"
 43.         replace education = . if mi(educationlevel)
 44. 
.         label def ethnicity 0 "Not Reported"
 45.         label def ethnicity 1 "American Indian or Alaska Native, not Hispanic", add
 46.         label def ethnicity 2 "Asian, not Hispanic", add
 47.         label def ethnicity 3 "Pacific Islander, not Hispanic", add
 48.         label def ethnicity 4 "Filipino, not Hispanic", add
 49.         label def ethnicity 5 "Hispanic or Latino", add
 50.         label def ethnicity 6 "African American, not Hispanic", add
 51.         label def ethnicity 7 "White, not Hispanic", add
 52.         label def ethnicity 9 "Two or More Races, not Hispanic", add
 53.         rename ethnicgroup ethnicity
 54.         label val ethnicity ethnicity
 55.         label var ethnicity "Staff member's racial/ethnic designation"
 56. 
.         label def race 1 "American Indian or Alaska Native"
 57.         label def race 2 "Asian", add
 58.         label def race 5 "Hispanic or Latino", add
 59.         label def race 6 "Black or African American", add
 60.         label def race 7 "White", add
 61.         label def race 8 "Two or More Races", add
 62.         gen race:race = 1 if ethnicity==1
 63.         replace race = 2 if inlist(ethnicity, 2, 3, 4)
 64.         replace race = 5 if ethnicity==5
 65.         replace race = 6 if ethnicity==6
 66.         replace race = 7 if ethnicity==7
 67.         replace race = 8 if ethnicity==9
 68.         label var race "Race"
 69. 
.         gen eth_american_indian = (race==1)
 70.         replace eth_american_indian = . if mi(race)
 71.         label var eth_american_indian "American Indian or Alaska Native"
 72. 
.         gen eth_asian = (race==2)
 73.         replace eth_asian = . if mi(race)
 74.         label var eth_asian "Asian"
 75. 
.         gen eth_hispanic = (race==5)
 76.         replace eth_hispanic = . if mi(race)
 77.         label var eth_hispanic "Hispanic or Latino"
 78. 
.         gen eth_black = (race==6)
 79.         replace eth_black = . if mi(race)
 80.         label var eth_black "Black or African American"
 81. 
.         gen eth_white = (race==7)
 82.         replace eth_white = . if mi(race)
 83.         label var eth_white "White"
 84. 
.         gen eth_biracial = (race==8)
 85.         replace eth_biracial = . if mi(race)
 86.         label var eth_biracial "Two or More Races"
 87. 
.         gen eth_other = inlist(race, 1, 8, .)
 88.         label var eth_other "Other Race"
 89. 
.         rename yearsteaching years_teaching
 90.         label var years_teaching "Total years of public and/or private educational service. Includes services in th
> is district, other districts, other states, and countries. Does not include substitute teaching or classified staff se
> rvice. The first year of service is counted as 1 year."
 91. 
.         rename yearsindistrict years_district
 92.         label var years_district "Total years of service in a certificated position in the district. The first year
>  of service is counted as 1 year."
 93. 
.         label var employmentstatuscode "Indicates whether the teacher's position is tenured, probationary, or long-ter
> m substitute or temporary employee"
 94. 
.         label def employment_status 1 "Long term substitute or temporary employee"
 95.         label def employment_status 2 "Probationary", add
 96.         label def employment_status 3 "Tenured", add
 97.         label def employment_status 4 "Other", add
 98.         gen employment_status:employment_status = 1 if employmentstatuscode=="L"
 99.         replace employment_status = 2 if employmentstatuscode=="P"
100.         replace employment_status = 3 if employmentstatuscode=="T"
101.         replace employment_status = 4 if employmentstatuscode=="O"
102.         replace employment_status = . if mi(employmentstatuscode)
103.         label var employment_status "Employment Status"
104. 
.         rename fteteaching fte_teach
105.         label var fte_teach "Full-time equivalent (FTE) teaching duties"
106. 
.         rename fteadministrative fte_admin
107.         label var fte_admin "FTE administrative duties"
108. 
.         rename ftepupilservices fte_pupil
109.         label var fte_pupil "FTE pupil services duties"
110. 
.         label var filecreated "Date that the file was created"
111. 
.         gen date_created = date(filecreated, "MDY")
112.         format date_created %td
113.         label var date_created "Date that the file was created"
114.         drop filecreated
115. 
.         gen year = `fall_year' + 1
116.         label var year "Year of Spring Semester"
117. 
.         order districtcode year recid
118.         sort districtcode year recid
119.         compress
120.         label data "California Department of Education Spring `=`fall_year' + 1' Staff Demographics Records"
121.         save $datadir_clean/cde/staffdemo/staffdemo_`=`fall_year' + 1'_clean.dta, replace
122. }
