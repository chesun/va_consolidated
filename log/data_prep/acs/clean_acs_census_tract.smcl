> 1_c03_007e s1901_c03_008e s1901_c03_009e s1901_c03_010e), mi
 90. 
.   //married-couple families median income
.   gen inc_median_mcfam = s1901_c03_012e
 91.   //married-couple families mean income
.   gen inc_mean_mcfam = s1901_c03_013e
 92. 
. 
.   *** Non-Family Households (c04)
.   //percent of non-family households with income less than $10k
.   egen inc_lt10k_nonfamhh_pct = rowtotal(s1901_c04_002e), mi
 93.   //percent of non-family households with income less than $15k
.   egen inc_lt15k_nonfamhh_pct = rowtotal(s1901_c04_002e s1901_c04_003e), mi
 94.   //percent of non-family households with income less than $25k
.   egen inc_lt25k_nonfamhh_pct = rowtotal(s1901_c04_002e s1901_c04_003e s1901_c04_004e), mi
 95.   //percent of non-family households with income < $35k
.   egen inc_lt35k_nonfamhh_pct = rowtotal(s1901_c04_002e s1901_c04_003e s1901_c04_004e s1901_c04_005e), mi
 96.   //percent of non-family households with income < $50k
.   egen inc_lt50k_nonfamhh_pct = rowtotal(s1901_c04_002e s1901_c04_003e s1901_c04_004e s1901_c04_005e s1901_c04_006e), 
> mi
 97.   //percent of non-family households with income < $75k
.   egen inc_lt75k_nonfamhh_pct = rowtotal(s1901_c04_002e s1901_c04_003e s1901_c04_004e s1901_c04_005e s1901_c04_006e s1
> 901_c04_007e), mi
 98.   //percent of non-family households with income < $100k
.   egen inc_lt100k_nonfamhh_pct = rowtotal(s1901_c04_002e s1901_c04_003e s1901_c04_004e s1901_c04_005e s1901_c04_006e s
> 1901_c04_007e s1901_c04_008e), mi
 99.   //percent of non-family households with income < $150k
.   egen inc_lt150k_nonfamhh_pct = rowtotal(s1901_c04_002e s1901_c04_003e s1901_c04_004e s1901_c04_005e s1901_c04_006e s
> 1901_c04_007e s1901_c04_008e s1901_c04_009e), mi
100.   //percent of non-family households with income < $200k
.   egen inc_lt200k_nonfamhh_pct = rowtotal(s1901_c04_002e s1901_c04_003e s1901_c04_004e s1901_c04_005e s1901_c04_006e s
> 1901_c04_007e s1901_c04_008e s1901_c04_009e s1901_c04_010e), mi
101. 
.   //non-family households median income
.   gen inc_median_nonfamhh = s1901_c04_012e
102.   //non-family households mean income
.   gen inc_mean_nonfamhh = s1901_c04_013e
103. 
.   keep geo_id name inc*
104.   rename geo_id geoid
105.   //generate the geoid2 var which is the last 11 digits of geoid
.   gen geoid2 = substr(geoid, 10, 11)
106.   rename name geodisplaylabel
107.   gen year = `year'
108.   order geoid geoid2 geodisplaylabel year
109.   isid geoid
110.   tempfile income_`year'
111.   save `income_`year''
112. 
. 
. 
.   ******************************************************************************
.   * Population: Subject Table S0601 *
.   ******************************************************************************
.   import delimited using $vaprojdir/data/public_access/raw/acs/subject_tables/`year'/5yr/ACSST5Y`year'.S0601_data_with
> _overlays.csv, clear varnames(1) case(lower)
113. 
.   foreach v of varlist * {
114.         di "`v'"
115.         //fist observation in each column is the var label
.         label var `v' `"`=`v'[1]'"'
116.         //define the var Characteristics
.         char `v'[varlabel] `"`=`v'[1]'"'
117.   }
118.   drop if _n==1
119. 
.   foreach v of varlist s* {
120.         destring `v', replace ignore(",+(X)-*Nnull")
121.   }
122. 
.   //total population between 5 and 17 years old = total population * percent between 5-17
.   gen pop_517_tot = s0601_c01_001e * (s0601_c01_003e / 100)
123.   //total population less than 18 years old
.   gen pop_lt18_tot = (s0601_c01_001e * (s0601_c01_002e / 100)) + (s0601_c01_001e * (s0601_c01_003e / 100))
124.   //total native populaiton
.   gen pop_native_tot = s0601_c02_001e + s0601_c03_001e + s0601_c04_001e
125.   //proportion of native population
.   gen pop_native_prop = pop_native_tot / s0601_c01_001e
126. 
.   //total native population between 5 and 17 years old
.   gen pop_517_native_tot = (s0601_c02_001e * (s0601_c02_003e / 100)) + (s0601_c03_001e * (s0601_c03_003e / 100)) + (s0
> 601_c04_001e * (s0601_c04_003e / 100))
127.   //proportion of native in the population between 5 and 17
.   gen pop_517_native_prop = pop_517_native_tot / pop_517_tot
128. 
.   //total native population less than 18 years old
.   gen pop_lt18_native_tot = pop_517_native_tot + (s0601_c02_001e * (s0601_c02_002e / 100)) + (s0601_c03_001e * (s0601_
> c03_002e / 100)) + (s0601_c04_001e * (s0601_c04_002e / 100))
129.   //proportion of native in the population less than 18
.   gen pop_lt18_native_prop = pop_lt18_native_tot / pop_lt18_tot
130. 
.   sum pop_*
131. 
.   //percentage of white
.   gen eth_white_pct = s0601_c01_014e
132.   //percentage of black
.   gen eth_black_pct = s0601_c01_015e
133.   //percentage of other race: lumping together American Indian, Native Hawaiian, one race- some other race, and two
>  or more races
.   egen eth_other_pct = rowtotal(s0601_c01_016e s0601_c01_018e s0601_c01_019e s0601_c01_020e)
134.   //percentage of Asian
.   gen eth_asian_pct = s0601_c01_017e
135.   //percentage of Hispanic
.   gen eth_hispanic_pct = s0601_c01_021e
136.   //percentage of non Hispanic white
.   gen eth_white_nonhispanic_pct = s0601_c01_022e
137. 
.   keep geo_id name pop_* eth_*
138.   rename geo_id geoid
139.   //generate the geoid2 var which is the last 11 digits of geoid
.   gen geoid2 = substr(geoid, 10, 11)
140.   rename name geodisplaylabel
141.   gen year = `year'
142.   order geoid geoid2 geodisplaylabel year
143.   isid geoid
144.   tempfile population_`year'
145.   save `population_`year''
146. 
. 
. 
.   ******************************************************************************
.   * Merge all the subject tables of each year *
.   ******************************************************************************
.   use `population_`year'', clear
147.   merge 1:1 geoid using `education_`year'', keep(3)
148.   drop _merge
149.   merge 1:1 geoid using `poverty_`year'', keep(3)
150.   drop _merge
151.   merge 1:1 geoid using `income_`year'', keep(3)
152.   drop _merge
153. 
.   compress
154.   order geoid geoid2 geodisplaylabel year
155.   sort geoid geoid2 year
156.   /* //save to my own folder while waiting for write access
>   save $projdir/dta/common_core_va/acs/acs_ca_census_tract_clean_`year'.dta, replace */
.   save $datadir_clean/acs/acs_ca_census_tract_clean_`year'.dta, replace
157. 
. }
