. foreach year in 2010 2011 2012 2013 {
  2. 
.   ******************************************************************************
.   * Education: Subject Table S1501 *
.   ******************************************************************************
. 
.   import delimited using $vaprojdir/data/public_access/raw/acs/subject_tables/`year'/5yr/ACSST5Y`year'.S1501_data_with
> _overlays.csv, clear varnames(1) case(lower)
  3. 
.   //assigning var labels using the second row
.   foreach v of varlist * {
  4.         label var `v' `"`=`v'[1]'"'
  5.         char `v'[varlabel] `"`=`v'[1]'"'
  6.   }
  7.   drop if _n==1
  8. 
.   //convert to numeric variables, and remove non-numeric characters specified in the ignore() option
.   foreach v of varlist s* {
  9.         destring `v', replace ignore(",+(X)-*null")
 10.   }
 11. 
.   *** Education level proportions
.   // proportion of high school dropouts in 25 years and over population: (less than 9th grade + 9-12th grade)/total
.   gen educ_hs_dropout_prop = (s1501_c01_007e + s1501_c01_008e) / s1501_c01_006e
 12.   // proportion of high school graduates
.   gen educ_deg_hs_prop = s1501_c01_009e / s1501_c01_006e
 13.   // proportion of some college, no degree
.   gen educ_some_college_prop = s1501_c01_010e / s1501_c01_006e
 14.   // proportion of associate's degree
.   gen educ_deg_2year_prop = s1501_c01_011e / s1501_c01_006e
 15.   // proportion of bachelor's degree
.   gen educ_deg_4year_prop = s1501_c01_012e / s1501_c01_006e
 16.   // proportion of graduate or professional degree
.   gen educ_deg_grad_prop = s1501_c01_013e / s1501_c01_006e
 17.   // proportion of 4 year degree or more
.   gen educ_deg_4year_plus_prop = (s1501_c01_012e + s1501_c01_013e) / s1501_c01_006e
 18. 
.   // temp var to check whether the data add up
.   tempvar tot_prop
 19.   gen `tot_prop' = (s1501_c01_007e + s1501_c01_008e + s1501_c01_009e + s1501_c01_010e + s1501_c01_011e + s1501_c01_
> 012e + s1501_c01_012e + s1501_c01_013e) / s1501_c01_006e
 20.   sum `tot_prop'
 21. 
.   keep educ* geo_id name
 22.   rename geo_id geoid
 23.   //generate the geoid2 var which is the last 11 digits of geoid
.   gen geoid2 = substr(geoid, 10, 11)
 24.   // the name var is the same as the old geodisplaylabel var, keep var name consistency
.   rename name geodisplaylabel
 25.   gen year = `year'
 26.   order geoid geoid2 geodisplaylabel year
 27.   //checks whether the geoid var uniquely identifies observations
.   isid geoid
 28.   tempfile education_`year'
 29.   save `education_`year''
 30. 
. 
.   ******************************************************************************
.   * Poverty: Subject Table S1702 *
.   ******************************************************************************
.   import delimited using $vaprojdir/data/public_access/raw/acs/subject_tables/`year'/5yr/ACSST5Y`year'.S1702_data_with
> _overlays.csv, clear varnames(1) case(lower)
 31. 
.   foreach v of varlist * {
 32.         label var `v' `"`=`v'[1]'"'
 33.         char `v'[varlabel] `"`=`v'[1]'"'
 34.   }
 35.   drop if _n==1
 36. 
.   foreach v of varlist s* {
 37.         destring `v', replace ignore(",+(X)-*Nnull")
 38.   }
 39. 
.   // total number of families with children under 18 years
.   gen fam_child_lt18_tot = s1702_c01_002e
 40.   // proportion of families with children under 18 years below poverty level
.   gen pov_fam_child_lt18_pct = s1702_c02_002e
 41. 
.   keep geo_id name fam_child_lt18_tot pov_fam_child_lt18_pct
 42.   rename geo_id geoid
 43.   //generate the geoid2 var which is the last 11 digits of geoid
.   gen geoid2 = substr(geoid, 10, 11)
 44.   rename name geodisplaylabel
 45.   gen year = `year'
 46.   order geoid geoid2 geodisplaylabel year
 47.   isid geoid
 48.   tempfile poverty_`year'
 49.   save `poverty_`year''
 50. 
. 
