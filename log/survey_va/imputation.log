. // do this for quality vars
. local xdummies

. foreach i of local qualityvars {
  2.   local xvars: list qualityvars - i
  3.   local minusvar imputed`i'
  4.   local xdummies: list qualityimputedummies - minusvar
  5.   reg `i' `xvars' `xdummies'
  6.   predict hat_`i'
  7.   replace `i' = hat_`i' if imputed`i' == 1
  8.   drop hat_`i'
  9. }
