. 
. 
. // do this for quality vars
. local xdummies

. foreach i of local qualityvars {
  2.   local xvars: list qualityvars - i
  3.   local minusvar imputed`i'
  4.   local xdummies: list qualityimputedummies - minusvar
  5.   reg `i' `xvars' `xdummies'
  6.   predict hat_`i'
  7.   replace `i' = hat_`i' if imputed`i' == 1
  8.   // clamp OLS-imputed predictions to the Likert range [-2, 2]: regression
.   // imputation is unbounded, so censor out-of-range predictions to the
.   // nearest bound (fixes secqoi27mean_pooled max=2.61 -> 2; check_survey_ind
> ices)
.   replace `i' = -2 if imputed`i' == 1 & `i' < -2
  9.   replace `i' =  2 if imputed`i' == 1 & `i' >  2 & !missing(`i')
 10.   drop hat_`i'
 11. }
