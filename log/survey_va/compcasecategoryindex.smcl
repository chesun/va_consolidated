. foreach index of local indexvars {
  2.   //merge the va index reg datasets to produce combined table
.   local merge_command use
  3.   local merge_options clear
  4. 
.   foreach va_outcome in ela math enr enr_2year enr_4year dk_enr dk_enr_2year dk_enr_4year {
  5.     di "va: `va_outcome'"
  6.     foreach sample in b las {
  7.       di "sample: `sample'"
  8.       foreach control of local `sample'_sample_controls {
  9.         //macro for whether to use the VA estimates with peer effects
.         if "`sample'" == "b" {
 10.           local peer
 11.           local peer_yn "N"
 12.         }
 13.         if "`sample'" == "las" {
 14.           local peer "_p"
 15.           local peer_yn "Y"
 16.         }
 17. 
.         di "peer controls in VA estimates (empty if no peer, _p if peer): `peer'"
 18. 
. 
.         `merge_command' $estimates_dir/survey_va/factor/compcase/va_`va_outcome'_`sample'_sp_`control'_ct`peer'_`index
> ', `merge_options'
 19. 
.         local merge_command "merge 1:1 var using"
 20.         local merge_options nogen
 21.       }
 22.     }
 23.   }
 24. 
.   save $estimates_dir/survey_va/factor/compcase/`index'_va_compregs, replace
 25.   export excel using $output_dir/csv/factoranalysis/compcase/`index'_va_compregs, replace firstrow(variables)
 26. }
