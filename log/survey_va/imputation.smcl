. ********************************************************************************
. /* Regress each var on other vars in each category and imputed dummies; predict y hat and replace missing with y hat *
> /
. // do this for climate vars
. local xdummies

. foreach i of local climatevars {
  2.   local xvars: list climatevars - i
  3.   local minusvar imputed`i'
  4.   local xdummies: list climateimputedummies - minusvar
  5.   reg `i' `xvars' `xdummies'
  6.   predict hat_`i'
  7.   replace `i' = hat_`i' if imputed`i' == 1
  8.   drop hat_`i'
  9. }
