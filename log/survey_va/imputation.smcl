. /* Note: NEED TO ADD VAR LABELS */
. 
. // generate an indicator for imputed qoi vars and assign a local macro for the imputation indicator dummies for each c
> ategory
. local climateimputedummies

. foreach i of local climatevars {
  2.   gen imputed`i' = 0
  3.   replace imputed`i' = 1 if missing(`i')
  4.   label var imputed`i' "dummy for whether variable `i' is imputed"
  5.   local addvar imputed`i'
  6.   local climateimputedummies: list climateimputedummies | addvar
  7. }
