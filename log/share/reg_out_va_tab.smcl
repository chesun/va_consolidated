. include $consolidated_dir/do/va/helpers/drift_limit.doh

. /*------------------------------------------------------------------------------
> do/va/helpers/drift_limit.doh — drift-limit constants for VA estimation
> ================================================================================
> 
> PURPOSE
>     Define `score_drift_limit' and `out_drift_limit' locals consumed by the
>     `vam' ado package for the score-VA and outcome-VA estimation loops.
> 
> INCLUDED FROM
>     Phase 3 VA estimation scripts under `do/va/' (e.g., va_score_all.do,
>     va_out_all.do, once relocated per plan v3 §3.3 step 3).  Must follow
>     `include do/va/helpers/macros_va.doh' since drift-limit definitions
>     depend on `test_score_min_year' / `_max_year' and `outcome_min_year' /
>     `_max_year' defined in macros_va.doh L35-65.
> 
> ROLE IN ADR-0021 SANDBOX
>     Pure local definitions; no reads, no writes; sandbox-trivially clean.
>     No `$global' references, so no LEGACY-include macro-trace concerns.
> 
> RELOCATION HISTORY (per ADR-0005 + ADR-0021, applied 2026-04-30)
>     Source:      cde_va_project_fork/do_files/sbac/drift_limit.doh
>     Destination: do/va/helpers/drift_limit.doh
>     Path repointing: none (no `$global' references).
>     Analysis logic preserved verbatim.
>     Predecessor caller-update protocol: predecessor callers untouched in
>     this commit per plan v3 §3.3 step 5 parenthetical (wholesale predecessor
>     retirement at Phase 1a §3.5 golden-master).
> 
> REFERENCES
>     Plan v3 §3.3 step 1 (helpers/macros)
>     ADR-0021 (description convention; sandbox role above)
> ------------------------------------------------------------------------------*/
. 
. /* set drift limit for test score VA */
. local score_drift_limit = max(`test_score_max_year' - `test_score_min_year' - 1, 1)

. /* set drift limit outcome VA */
. local out_drift_limit = max(`outcome_max_year' - `outcome_min_year' - 1, 1)

. 
. 
. local sp_ct_p_combos b_sp_b_ct las_sp_b_ct las_sp_b_ct_p las_sp_las_ct_p las_sp_lasd_ct_p

. 
. 
. 
. 
. foreach version in v1 v2 {
  2.   cap mkdir "$estimates_dir"
  3.   cap mkdir "$estimates_dir/va_cfr_all_`version'"
  4.   cap mkdir "$estimates_dir/va_cfr_all_`version'/reg_out_va"
  5.   //----------------------------------------------------------------------------
.   //  regressions on only 1 subject VA estimate
.   //----------------------------------------------------------------------------
. 
.   // merge the regsave datasets for each subject
. 
. 
.   foreach subject in ela math {
  6.     local append_command use
  7.     local append_option ", clear"
  8. 
.     foreach outcome in enr_2year enr_4year {
  9.       foreach sample_control_peer of local sp_ct_p_combos {
 10.         `append_command' "$estimates_dir/va_cfr_all_`version'/reg_out_va/reg_`outcome'_va_`subject'_`sample_control
> _peer'_m.dta" `append_option'
 11. 
.         keep if strpos(var, "va_`subject'")~=0
 12. 
.         local append_command "append using"
 13.         local append_option
 14.       }
 15.     }
 16. 
.     save "$estimates_dir/va_cfr_all_`version'/reg_out_va/reg_out_`subject'_m.dta", replace
 17. 
. 
. 
.   }
 18. 
. 
.   //----------------------------------------------------------------------------
.   //  regressions on both subjects VA estimate
.   //----------------------------------------------------------------------------
.   local append_command use
 19.   local append_option ", clear"
 20. 
.   foreach outcome in enr_2year enr_4year {
 21.     foreach sample_control_peer of local sp_ct_p_combos {
 22.       `append_command' "$estimates_dir/va_cfr_all_`version'/reg_out_va/reg_`outcome'_va_ela_math_`sample_control_pe
> er'_m.dta" `append_option'
 23. 
.       local append_command "append using"
 24.       local append_option
 25.     }
 26.   }
 27.     keep if strpos(var, "va_ela")!=0 | strpos(var, "va_math")!=0
 28.     save "$estimates_dir/va_cfr_all_`version'/reg_out_va/reg_out_both_m.dta", replace
 29. 
. 
. 
. 
. 
. **********************************************************************************
. 
. 
. 
.   //------------------------------------------------------------------
.   //  rearrange the dataset into table format: single subject regs
.   //------------------------------------------------------------------
.   foreach subject in math ela {
 30.     use "$estimates_dir/va_cfr_all_`version'/reg_out_va/reg_out_`subject'_m.dta", clear
 31.     // column groups
.     gen colgroup=1 if outcome=="enr_2year"
 32.     replace colgroup=2 if outcome=="enr_4year"
 33. 
.     // column numbers in each column group
.     gen column = (colgroup-1)*4 + 1 if sample=="b"
 34.     replace column = (colgroup-1)*4 + 2 if sample=="las" & control=="b" & peer=="N"
 35.     replace column = (colgroup-1)*4 + 3 if sample=="las" & control=="b" & peer=="Y"
 36.     replace column = (colgroup-1)*4 + 4 if sample=="las" & control=="las"
 37.     drop if column==.
 38. 
.     drop r2
 39.     foreach var of varlist coef  stderr {
 40.       tostring `var', force format(%10.3f) replace
 41.     }
 42.     replace stderr="("+ stderr+ ")"
 43.     replace coef=coef+"*" if pval<.05
 44.     replace coef=coef+"*" if pval<.01
 45.     replace coef=coef+"*" if pval<.001
 46. 
.     tostring N, force replace format("%9.0fc")
 47. 
.     drop pval subject
 48. 
.     replace outcome="2-Year Enrollment" if outcome=="enr_2year"
 49.     replace outcome="4-Year Enrollment" if outcome=="enr_4year"
 50. 
.     replace sample="Base" if sample=="b"
 51.     replace sample="Restricted" if sample=="las"
 52. 
.     replace control="Base" if control=="b"
 53.     replace control="Leave Out Score + ACS + Sibling" if control=="las"
 54. 
.     foreach var of varlist coef stderr N outcome sample control reg_control peer {
 55.       rename `var' entry`var'
 56.     }
 57. 
. 
.     reshape long entry, i(column var) j(row) string
 58. 
. 
. 
.     gen rownumber=1 if row=="coef"
 59.     replace rownumber=2 if row=="stderr"
 60.     replace rownumber=3 if row=="N"
 61.     replace rownumber=4 if row=="peer"
 62.     replace rownumber=5 if row=="reg_control"
 63.     replace rownumber=6 if row=="sample"
 64.     replace rownumber=7 if row=="control"
 65. 
.     drop if rownumber==.
 66.     drop var colgroup
 67. 
.     reshape wide entry, i(rownumber) j(column)
 68. 
.     gen subject="`subject'"
 69. 
.     replace row="``subject'_str' VA" if row=="coef"
 70.     replace row="" if row=="stderr"
 71.     replace row="Peer" if row=="peer"
 72.     replace row="Regression Controls" if row=="reg_control"
 73.     replace row="VA Sample" if row=="sample"
 74.     replace row="VA Controls" if row=="control"
 75. 
. 
.     sort rownumber
 76.     order row entry*
 77. 
.     tempfile `subject'
 78.     save ``subject''
 79. 
. 
. 
. 
.   }
 80. 
.   append using `math'
 81. 
.   drop if rownumber>=4 & rownumber<=7 & subject=="ela"
 82.   drop subject rownumber
 83. 
. 
.   local single_texsave_options autonumber nonames replace size(footnotesize) hlines(3 -4) ///
>     /* title("Regressing College Enrollment on Single Subject Test Score VA")  */ ///
>     headerlines("& \multicolumn{4}{c}{2-Year Enrollment} & \multicolumn{4}{c}{4-Year Enrollment} " "\cmidrule(lr){2-5}
>  \cmidrule(lr){6-9}")
 84.     /* footnote("Standard errors in paranthesis. * \(p<0.05)\) ** \(p<0.01\) *** \(p<0.001\)") */
. 
.   // a folder for checking the tables
.   texsave using "$tables_dir/share/va/check/persistence_single_subject.tex", `single_texsave_options'
 85. 
.   // folder for publication ready tables using the frag option for texsave
.   texsave using "$tables_dir/share/va/pub/persistence_single_subject.tex", `single_texsave_options' frag
 86. 
. 
. 
. 
. 
.   //------------------------------------------------------------------
.   //  rearrange the dataset into table format: both subjects regs
.   //------------------------------------------------------------------
. 
.   use "$estimates_dir/va_cfr_all_`version'/reg_out_va/reg_out_both_m.dta", clear
 87.   // column groups
.   gen colgroup=1 if outcome=="enr_2year"
 88.   replace colgroup=2 if outcome=="enr_4year"
 89. 
.   // column numbers in each column group
.   gen column = (colgroup-1)*4 + 1 if sample=="b"
 90.   replace column = (colgroup-1)*4 + 2 if sample=="las" & control=="b" & peer=="N"
 91.   replace column = (colgroup-1)*4 + 3 if sample=="las" & control=="b" & peer=="Y"
 92.   replace column = (colgroup-1)*4 + 4 if sample=="las" & control=="las"
 93.   drop if column==.
 94. 
.   drop r2
 95.   foreach var of varlist coef  stderr {
 96.     tostring `var', force format(%10.3f) replace
 97.   }
 98.   replace stderr="("+ stderr+ ")"
 99.   replace coef=coef+"*" if pval<.05
100.   replace coef=coef+"*" if pval<.01
101.   replace coef=coef+"*" if pval<.001
102. 
. 
. 
.   tostring N, force replace format("%9.0fc")
103. 
.   drop pval subject
104. 
.   gen va_ela=1 if strpos(var, "va_ela")==1
105.   replace va_ela=0 if strpos(var, "va_math")==1
106. 
. 
.   replace outcome="2-Year Enrollment" if outcome=="enr_2year"
107.   replace outcome="4-Year Enrollment" if outcome=="enr_4year"
108. 
.   replace sample="Base" if sample=="b"
109.   replace sample="Restricted" if sample=="las"
110. 
.   replace control="Base" if control=="b"
111.   replace control="Leave Out Score + ACS + Sibling" if control=="las"
112. 
.   foreach var of varlist coef stderr N outcome sample control reg_control peer {
113.     rename `var' entry`var'
114.   }
115. 
. 
. 
.   reshape long entry, i(column var) j(row) string
116. 
. 
. 
.   gen rowgroup=1 if va_ela==1
117.   replace rowgroup=2 if va_ela==0
118.   replace rowgroup=3 if row=="peer" | row=="reg_control" | row=="sample" | row=="control"
119. 
.   gen rownumber=(rowgroup-1)*2 + 1 if row=="coef"
120.   replace rownumber=(rowgroup-1)*2 + 2 if row=="stderr"
121. 
.   drop if va_ela==1 & (row=="peer" | row=="reg_control" | row=="sample" | row=="control" | row=="N")
122. 
.   replace rownumber=5 if row=="N"
123.   replace rownumber=6 if rowgroup==3 & row=="peer"
124.   replace rownumber=7 if rowgroup==3 & row=="reg_control"
125.   replace rownumber=8 if rowgroup==3 & row=="sample"
126.   replace rownumber=9 if rowgroup==3 & row=="control"
127. 
.   drop if rownumber==.
128.   drop var va_ela colgroup rowgroup
129. 
.   reshape wide entry, i(rownumber) j(column)
130. 
.   replace row="ELA VA" if rownumber==1
131.   replace row="Math VA" if rownumber==3
132.   replace row="" if row=="stderr"
133.   replace row="Peer" if row=="peer"
134.   replace row="Regression Controls" if row=="reg_control"
135.   replace row="VA Sample" if row=="sample"
136.   replace row="VA Controls" if row=="control"
137. 
.   sort rownumber
138.   order row entry*
139.   drop rownumber
140. 
. 
. 
.   local single_texsave_options autonumber nonames replace size(footnotesize) hlines(-4) ///
>     title("Regressing College Enrollment on Both ELA and Math Test Score VA simultaneously") ///
>     headerlines("& \multicolumn{4}{c}{2-Year Enrollment} & \multicolumn{4}{c}{4-Year Enrollment} " "\cmidrule(lr){2-5}
>  \cmidrule(lr){6-9}") ///
>     footnote("Standard errors in paranthesis. * \(p<0.05)\) ** \(p<0.01\) *** \(p<0.001\)")
141. 
.   // a folder for checking the tables
.   texsave using "$tables_dir/share/va/check/persistence_both_subject.tex", `single_texsave_options'
142. 
.   // folder for publication ready tables using the frag option for texsave
.   texsave using "$tables_dir/share/va/pub/persistence_both_subject.tex", `single_texsave_options' frag
143. 
. 
. 
. 
. 
. 
. }
