# ==============================================================================
# .gitignore — Academic Claude Code Projects
# ==============================================================================

# --- LaTeX build artifacts ---
# Bare *.log and *.out are NOT used — they collide with Stata logs and
# shell nohup.out, respectively. Scope both to LaTeX directories.
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.lof
*.lot
*.nav
*.run.xml
*.snm
*.synctex.gz
*.toc
*.vrb
*-blx.bib
paper/**/*.log
paper/**/*.out
talks/**/*.log
talks/**/*.out
slides/**/*.log
slides/**/*.out
supplementary/**/*.log
supplementary/**/*.out

# --- Python ---
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/
.ipynb_checkpoints/

# Always track dependency manifests (anti-rules — never ignore these)
!requirements.txt
!requirements-*.txt
!environment.yml
!pyproject.toml
!Pipfile
!Pipfile.lock

# --- R ---
.Rproj.user/
.Rhistory
.RData
.Rdata
.Ruserdata

# --- OS ---
.DS_Store
Thumbs.db

# --- Claude Code (local-only, not shared across machines) ---
.claude/settings.local.json
.claude/state/*
!.claude/state/primary_source_surnames.txt
!.claude/state/verification-ledger.md
.claude/worktrees/
CLAUDE.local.md

# --- IDE / editor noise ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Quarto ---
/.quarto/

# --- Compiled PDFs (uncomment per project to track specific outputs) ---
# *.pdf

# --- Output artifacts (uncomment per project) ---
# *.rds
# output/**/*.rds
