# ==============================================================================
# .gitignore — Academic Claude Code Projects
# ==============================================================================

# --- LaTeX build artifacts ---
# Bare *.log and *.out are NOT used — they collide with Stata logs and
# shell nohup.out, respectively. Scope both to LaTeX directories.
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.lof
*.lot
*.nav
*.run.xml
*.snm
*.synctex.gz
*.toc
*.vrb
*-blx.bib
paper/**/*.log
paper/**/*.out
talks/**/*.log
talks/**/*.out
slides/**/*.log
slides/**/*.out
supplementary/**/*.log
supplementary/**/*.out

# --- Python ---
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/
.ipynb_checkpoints/

# Always track dependency manifests (anti-rules — never ignore these)
!requirements.txt
!requirements-*.txt
!environment.yml
!pyproject.toml
!Pipfile
!Pipfile.lock

# --- R ---
.Rproj.user/
.Rhistory
.RData
.Rdata
.Ruserdata

# --- OS ---
.DS_Store
Thumbs.db

# --- Codebook exports (may surface restricted-access metadata in
#     `codebook` Examples blocks for ID / name / DOB string variables) ---
master_supporting_docs/codebooks/

# --- Stata + project data artifacts (per ADR-0007) ---
# Code in git, data on Scribe.  These dirs/extensions are NEVER tracked:
# they hold restricted-access data, large estimates, or run-time output
# that should never leave the Scribe filesystem.  The repo's role per
# ADR-0007 is code + docs + tables + figures only.
data/
estimates/
log/
output/
*.dta
*.smcl
*.ster
# Note: bare `*.log` is NOT excluded (would conflict with shell nohup.out
# and other tools).  Stata `.smcl` master logs ARE excluded above; the
# translated `.log` companion files land in log/ which is also gitignored,
# so they're covered by the dir-level rule.  Codebook export logs land
# in master_supporting_docs/codebooks/ which is gitignored above.

# --- Claude Code (local-only, not shared across machines) ---
.claude/settings.local.json
.claude/state/*
!.claude/state/primary_source_surnames.txt
!.claude/state/verification-ledger.md
.claude/worktrees/
CLAUDE.local.md

# --- IDE / editor noise ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Quarto ---
/.quarto/

# --- Compiled PDFs (uncomment per project to track specific outputs) ---
# *.pdf

# --- Output artifacts (uncomment per project) ---
# *.rds
# output/**/*.rds
